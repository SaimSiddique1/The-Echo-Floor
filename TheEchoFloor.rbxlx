      <Item class="ModuleScript" referent="21">
        <Properties>
          <string name="Name">AnomalySwapper</string>
          <string name="Source"><![CDATA[-- AnomalySwapper.luau (ModuleScript)
-- Exports: swapAnomaly() — picks one target, hides original, shows replacement

local SwapConfig = require(game.ReplicatedStorage.Shared.AnomalySwapConfig)

local FLOOR_SURFACE_Y = 0.5
local usedAnomalies = {}

local function liftAboveFloor(inst)
	local parts = {}
	if inst:IsA("BasePart") then
		parts = { inst }
	elseif inst:IsA("Model") then
		for _, v in inst:GetDescendants() do
			if v:IsA("BasePart") then
				table.insert(parts, v)
			end
		end
	end
	for _, p in ipairs(parts) do
		local top = p.Position.Y + p.Size.Y / 2
		if top <= FLOOR_SURFACE_Y then
			p.CFrame = p.CFrame + Vector3.new(0, FLOOR_SURFACE_Y - top + 0.05, 0)
		end
	end
end

local function moveTo(obj, cf)
	if obj:IsA("BasePart") then
		obj.CFrame = cf
	elseif obj:IsA("Model") then
		local parts = {}
		for _, v in obj:GetDescendants() do
			if v:IsA("BasePart") then
				table.insert(parts, v)
			end
		end
		if #parts > 0 then
			local saved = {}
			local min, max = Vector3.new(math.huge, math.huge, math.huge), Vector3.new(-math.huge, -math.huge, -math.huge)
			for _, p in ipairs(parts) do
				saved[p] = p.CFrame
				local pos = p.Position
				min = Vector3.new(math.min(min.X, pos.X), math.min(min.Y, pos.Y), math.min(min.Z, pos.Z))
				max = Vector3.new(math.max(max.X, pos.X), math.max(max.Y, pos.Y), math.max(max.Z, pos.Z))
				p.CanQuery = true
			end
			local center = (min + max) / 2
			local oldCenterCF = CFrame.new(center)
			for _, p in ipairs(parts) do
				local relCF = oldCenterCF:ToObjectSpace(saved[p])
				p.CFrame = cf * relCF
			end
		end
	end
	if cf.Position.Y > -50 then
		liftAboveFloor(obj)
		if obj:IsA("BasePart") then
			print("lifted", obj.Name, "to", obj.Position.Y)
		end
	end
end

local function getTargets()
	local floor = workspace:FindFirstChild("Floor")
	if not floor then return {} end
	local targets = {}
	for _, v in floor:GetDescendants() do
		if v:GetAttribute("AnomalyTarget") then
			table.insert(targets, v)
		end
	end
	return targets
end

local function getReplacement(targetName)
	local floor = workspace:FindFirstChild("Floor")
	if not floor then return nil end
	local anomalyFolder = floor:FindFirstChild("Anomaly")
	if not anomalyFolder then return nil end
	for _, v in anomalyFolder:GetChildren() do
		if v:GetAttribute("Replaces") == targetName then
			return v
		end
	end
	return nil
end

local function hideAllReplacements()
	local floor = workspace:FindFirstChild("Floor")
	if not floor then return end
	local anomalyFolder = floor:FindFirstChild("Anomaly")
	if not anomalyFolder then return end
	for _, v in anomalyFolder:GetChildren() do
		local replaces = v:GetAttribute("Replaces")
		if replaces and SwapConfig[replaces] then
			moveTo(v, SwapConfig[replaces].replacementHide)
		end
	end
end

local function revertAll()
	local floor = workspace:FindFirstChild("Floor")
	if not floor then return end

	for _, v in floor:GetDescendants() do
		if v:GetAttribute("AnomalyTarget") then
			local config = SwapConfig[v.Name]
			if config then
				moveTo(v, config.show)
			end
		end
	end

	hideAllReplacements()
end

local function swapAnomaly()
	hideAllReplacements()

	local targets = getTargets()
	if #targets == 0 then
		warn("No AnomalyTarget objects found")
		return nil
	end

	local available = {}
	for _, t in ipairs(targets) do
		if not usedAnomalies[t.Name] then
			table.insert(available, t)
		end
	end

	if #available == 0 then
		warn("All anomalies already used in this session")
		usedAnomalies = {}
		for _, t in ipairs(targets) do
			table.insert(available, t)
		end
	end

	local chosen = available[math.random(1, #available)]
	local chosenName = chosen.Name
	usedAnomalies[chosenName] = true

	local config = SwapConfig[chosenName]
	if not config then
		warn("No swap config for: " .. chosenName)
		return nil
	end

	local replacement = getReplacement(chosenName)
	if not replacement then
		warn("No replacement found for: " .. chosenName)
		return nil
	end

	moveTo(chosen, config.hide)
	moveTo(replacement, config.replacementShow)
	replacement.Name = chosenName

	local parts = {}
	if replacement:IsA("BasePart") then
		parts = { replacement }
	elseif replacement:IsA("Model") then
		for _, v in replacement:GetDescendants() do
			if v:IsA("BasePart") then table.insert(parts, v) end
		end
	end
	for _, p in ipairs(parts) do
		p.Transparency = 0
	end

	print("Anomaly activated: " .. chosenName)
	if replacement:IsA("Model") then
		local pc = {}
		for _, v in replacement:GetDescendants() do
			if v:IsA("BasePart") then table.insert(pc, v) end
		end
		print("  replacement parts:", #pc)
		for _, p in ipairs(pc) do
			print("    ", p.Name, p.Position.Y, p.Size.Y)
		end
	elseif replacement:IsA("BasePart") then
		print("  BasePart at", replacement.Position.Y, "size", replacement.Size.Y)
	end
	return chosenName
end

local function resetUsed()
	usedAnomalies = {}
end

return { swapAnomaly = swapAnomaly, revertAll = revertAll, resetUsed = resetUsed }
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="22">
        <Properties>
          <string name="Name">FloorCloner</string>
          <string name="Source"><![CDATA[-- FloorCloner.luau (ModuleScript)
-- Exports: spawnFloor() — clones floor template into Workspace, destroys previous

local ServerStorage = game:GetService("ServerStorage")
local Workspace = game:GetService("Workspace")

local TEMPLATES = ServerStorage.Templates

local function destroyScripts(inst)
	for _, child in inst:GetDescendants() do
		if child:IsA("Script") or child:IsA("LocalScript") or child:IsA("ModuleScript") or child:IsA("PackageLink") then
			child:Destroy()
		end
	end
	-- Also catch anything named "PoseTexture" or "Package"
	for _, child in inst:GetDescendants() do
		if child.Name == "PoseTexture" or child.Name == "Package" then
			child:Destroy()
		end
	end
end

local function anchorAll(inst)
	for _, child in inst:GetDescendants() do
		if child:IsA("BasePart") then
			child.Anchored = true
		end
	end
end

local function spawnFloor()
	local existing = Workspace:FindFirstChild("Floor")
	if existing then
		existing:Destroy()
	end

	local template = TEMPLATES:FindFirstChild("Floor")
	if not template then
		warn("Floor not found in ServerStorage.Templates")
		return nil
	end

	local floor = template:Clone()
	destroyScripts(floor)
	anchorAll(floor)
	floor.Parent = Workspace
	print("Floor spawned into Workspace")
	return floor
end

return { spawnFloor = spawnFloor }
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="23">
        <Properties>
          <string name="Name">LeaderboardService</string>
          <string name="Source"><![CDATA[local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")

local statsStore = DataStoreService:GetDataStore("PlayerStats")
local leaderStore = DataStoreService:GetOrderedDataStore("Leaderboard")

local function defaultStats()
	return {
		points = 0,
		correct = 0,
		wrong = 0,
		abstained = 0,
		gamesPlayed = 0,
	}
end

local function createLeaderstats(player, data)
	local ls = Instance.new("Folder")
	ls.Name = "leaderstats"

	local points = Instance.new("IntValue")
	points.Name = "Points"
	points.Value = data.points
	points.Parent = ls

	local correct = Instance.new("IntValue")
	correct.Name = "Correct"
	correct.Value = data.correct
	correct.Parent = ls

	local wrong = Instance.new("IntValue")
	wrong.Name = "Wrong"
	wrong.Value = data.wrong
	wrong.Parent = ls

	local abstained = Instance.new("IntValue")
	abstained.Name = "Abstained"
	abstained.Value = data.abstained
	abstained.Parent = ls

	local rounds = Instance.new("IntValue")
	rounds.Name = "Rounds"
	rounds.Value = data.gamesPlayed
	rounds.Parent = ls

	ls.Parent = player
end

local function loadStats(userId)
	local success, data = pcall(function()
		return statsStore:GetAsync(tostring(userId))
	end)
	if success and data then
		return data
	end
	return defaultStats()
end

local function saveStats(userId, data)
	pcall(function()
		statsStore:SetAsync(tostring(userId), data)
	end)
	pcall(function()
		leaderStore:SetAsync(tostring(userId), data.points)
	end)
end

local function updateStats(player, correct, abstained)
	local data = loadStats(player.UserId)
	if correct then
		data.correct += 1
		data.points += 10
	elseif abstained then
		data.abstained += 1
	else
		data.wrong += 1
		data.points -= 5
	end
	data.gamesPlayed += 1
	saveStats(player.UserId, data)

	local ls = player:FindFirstChild("leaderstats")
	if ls then
		local p = ls:FindFirstChild("Points")
		if p then p.Value = data.points end
		local c = ls:FindFirstChild("Correct")
		if c then c.Value = data.correct end
		local w = ls:FindFirstChild("Wrong")
		if w then w.Value = data.wrong end
		local a = ls:FindFirstChild("Abstained")
		if a then a.Value = data.abstained end
		local r = ls:FindFirstChild("Rounds")
		if r then r.Value = data.gamesPlayed end
	end
end

local function init()
	Players.PlayerAdded:Connect(function(player)
		local data = loadStats(player.UserId)
		createLeaderstats(player, data)
	end)

	Players.PlayerRemoving:Connect(function(player)
		local ls = player:FindFirstChild("leaderstats")
		if ls then
			local data = {
				points = ls.Points and ls.Points.Value or 0,
				correct = ls.Correct and ls.Correct.Value or 0,
				wrong = ls.Wrong and ls.Wrong.Value or 0,
				abstained = ls.Abstained and ls.Abstained.Value or 0,
				gamesPlayed = ls.Rounds and ls.Rounds.Value or 0,
			}
			saveStats(player.UserId, data)
		end
	end)
end

return {
	init = init,
	updateStats = updateStats,
}
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="24">
        <Properties>
          <string name="Name">MatchmakingService</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- MatchmakingService.server.luau
-- Queue: walk into bay → countdown on screen → exit button → teleport at 0

local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Remotes = ReplicatedStorage.Remotes

local BAY_TIMER = 10
local MAX_PLAYERS = 8
local LOBBY_NAME = "Lobby"
local BAY_DETECTOR_NAME = "BayDetector"

local bayPlayers = {}
local countdownActive = false
local currentTimer = BAY_TIMER
local bayCenter, bayRadius

-- Find parts
local function findLobby()
	return Workspace:FindFirstChild(LOBBY_NAME)
end

local function findDetector()
	local lobby = findLobby()
	if lobby then
		return lobby:FindFirstChild(BAY_DETECTOR_NAME)
	end
	return nil
end

local function findSpawnPoint()
	local lobby = findLobby()
	if lobby then
		local spawn = lobby:FindFirstChildOfClass("SpawnLocation")
		if spawn then
			return spawn.CFrame + Vector3.new(0, 3, 0)
		end
	end
	return CFrame.new(0, 1003, 0)
end

local function findGameTeleport()
	local elevator = Workspace:FindFirstChild("Elevator")
	if elevator then
		local target = elevator:FindFirstChild("TeleportTarget")
		if target then
			return target.CFrame + Vector3.new(0, 3, 0)
		end
	end
	return CFrame.new(0, 3, 0)
end

-- Send queue UI state to a player
local function sendUI(player, show, seconds, count)
	Remotes.QueueUpdate:FireClient(player, {
		show = show,
		seconds = seconds or 0,
		count = count or 0,
	})
end

-- Update UI for all bay players
local function broadcastUI(show, seconds)
	local count = #bayPlayers
	for _, player in ipairs(bayPlayers) do
		sendUI(player, show, seconds, count)
	end
end

-- Lobby music
local lobbyMusic = Instance.new("Sound")
lobbyMusic.Name = "LobbyMusic"
lobbyMusic.SoundId = "rbxassetid://1848354536"
lobbyMusic.Volume = 0.4
lobbyMusic.Looped = true
lobbyMusic.Parent = game:GetService("SoundService")

local function startLobbyMusic()
	if not lobbyMusic.Playing then
		lobbyMusic:Play()
	end
end

local function stopLobbyMusic()
	lobbyMusic:Stop()
end

-- Teleport player to game
local function teleportToGame(player)
	local cf = findGameTeleport()
	local char = player.Character
	if char and char:FindFirstChild("HumanoidRootPart") then
		char.HumanoidRootPart.CFrame = cf
	end
end

-- Teleport player back to lobby
local function teleportToLobby(player)
	local cf = findSpawnPoint()
	local char = player.Character
	if char and char:FindFirstChild("HumanoidRootPart") then
		char.HumanoidRootPart.CFrame = cf
	end
end

-- Start the round
local function startRound()
	if #bayPlayers == 0 then return end

	local players = {}
	for _, p in ipairs(bayPlayers) do
		table.insert(players, p)
	end

	-- Clear queue before teleporting
	local toTeleport = {}
	for _, p in ipairs(bayPlayers) do
		table.insert(toTeleport, p)
	end
	bayPlayers = {}
	countdownActive = false
	stopLobbyMusic()

	for _, player in ipairs(toTeleport) do
		sendUI(player, false, 0, 0)
		teleportToGame(player)
	end

	task.wait(0.5)

	local RoundRunner = require(script.Parent:FindFirstChild("RoundRunner"))
	if RoundRunner and RoundRunner.Start then
		RoundRunner.Start(toTeleport)
	end
end

-- Check if a player is still inside the bay (distance check)
local function isInBay(player)
	if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
		return false
	end
	return (player.Character.HumanoidRootPart.Position - bayCenter).Magnitude <= bayRadius
end

-- Remove players who left the bay
local function purgeLeavers()
	for i = #bayPlayers, 1, -1 do
		local player = bayPlayers[i]
		if not isInBay(player) then
			sendUI(player, false, 0, 0)
			table.remove(bayPlayers, i)
		end
	end
end

-- Countdown loop
local function runCountdown()
	countdownActive = true
	currentTimer = BAY_TIMER

	while countdownActive and #bayPlayers > 0 do
		purgeLeavers()
		if #bayPlayers == 0 then break end

		broadcastUI(true, currentTimer)

		if currentTimer <= 0 then
			startRound()
			return
		end

		task.wait(1)
		currentTimer -= 1

		if #bayPlayers >= MAX_PLAYERS and currentTimer > 3 then
			currentTimer = 3
		end
	end

	-- No players left
	broadcastUI(false, 0)
	countdownActive = false
end

-- Player enters the bay
local function onPlayerEntered(player)
	for _, v in ipairs(bayPlayers) do
		if v == player then return end
	end
	table.insert(bayPlayers, player)
	sendUI(player, true, currentTimer, #bayPlayers)

	if not countdownActive then
		coroutine.wrap(runCountdown)()
	end
end

-- Player leaves the bay
local function onPlayerLeft(player)
	for i, v in ipairs(bayPlayers) do
		if v == player then
			table.remove(bayPlayers, i)
			sendUI(player, false, 0, 0)
			break
		end
	end
end

-- Player leaves via exit button
Remotes.QueueExit.OnServerEvent:Connect(function(player)
	onPlayerLeft(player)
	teleportToLobby(player)
end)

-- Detect players entering the bay
local function setupDetector()
	local detector = findDetector()
	if not detector then
		warn("BayDetector not found")
		return
	end

	local cf = detector.CFrame
	local sz = detector.Size
	bayCenter = cf.Position
	bayRadius = math.max(sz.X, sz.Z) / 2 + 2

	local prompt = Instance.new("ProximityPrompt")
	prompt.Name = "QueuePrompt"
	prompt.ActionText = "Join Queue"
	prompt.ObjectText = "Elevator Bay"
	prompt.HoldDuration = 0
	prompt.MaxActivationDistance = 8
	prompt.Parent = detector

	prompt.Triggered:Connect(function(player)
		onPlayerEntered(player)
	end)
end

-- Player disconnected
local function onPlayerRemoved(player)
	onPlayerLeft(player)
end

-- Return players to lobby after round ends
local function returnAllPlayers(players)
	for _, player in ipairs(players) do
		teleportToLobby(player)
	end
	startLobbyMusic()
end

-- Init
local function init()
	setupDetector()
	Players.PlayerRemoving:Connect(onPlayerRemoved)
	local LeaderboardService = require(script.Parent.LeaderboardService)
	LeaderboardService.init()
	startLobbyMusic()
	print("MatchmakingService ready")
end

local api = {}
api.returnAllPlayers = returnAllPlayers
api.teleportToLobby = teleportToLobby
api.teleportToGame = teleportToGame

init()
return api
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="25">
        <Properties>
          <string name="Name">RoundRunner</string>
          <string name="Source"><![CDATA[-- RoundRunner.luau (ModuleScript)
-- Exports: Start(players) — runs the full round lifecycle

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

local FloorCloner = require(script.Parent.FloorCloner)
local AnomalySwapper = require(script.Parent.AnomalySwapper)
local LeaderboardService = require(script.Parent.LeaderboardService)
local Remotes = ReplicatedStorage.Remotes

local EXPLORE_TIME = 5
local GOING_UP_TIME = 5
local SEARCH_TIME = 30
local CHAT_TIME = 30
local REVEAL_TIME = 8
local BOARDING_TIME = 5
local MAX_ANOMALY_FLOORS = 3
local scores = {}

local function findElevator()
	return Workspace:FindFirstChild("Elevator")
end

local doorClosedL, doorClosedR

local function cacheDoorPositions()
	local elevator = findElevator()
	if not elevator then return end
	local dl = elevator:FindFirstChild("Door_Left")
	local dr = elevator:FindFirstChild("Door_Right")
	if dl and dr then
		doorClosedL = dl.CFrame
		doorClosedR = dr.CFrame
	end
end

local function getOrCreateMusic(elevator)
	local m = elevator:FindFirstChild("ElevatorMusic")
	if not m then
		m = Instance.new("Sound")
		m.Name = "ElevatorMusic"
		m.SoundId = "rbxassetid://1837198630"
		m.Volume = 0.4
		m.Looped = true
		m.Parent = elevator
	end
	return m
end

local function startElevatorMusic()
	local elevator = findElevator()
	if not elevator then return end
	getOrCreateMusic(elevator):Play()
end

local function stopElevatorMusic()
	local elevator = findElevator()
	if elevator then
		local m = elevator:FindFirstChild("ElevatorMusic")
		if m then m:Stop() end
	end
end

local function playDing()
	local elevator = findElevator()
	if not elevator then return end
	stopElevatorMusic()
	local s = elevator:FindFirstChild("Ding")
	if s and s:IsA("Sound") then
		s:Play()
		task.delay(0.9, function()
			s:Stop()
		end)
	end
end

local function setDoors(open)
	if not doorClosedL or not doorClosedR then
		cacheDoorPositions()
	end
	if not doorClosedL or not doorClosedR then return end

	local elevator = findElevator()
	local doorL = elevator and elevator:FindFirstChild("Door_Left")
	local doorR = elevator and elevator:FindFirstChild("Door_Right")
	if not doorL or not doorR then return end

	local offset = doorL.Size.Z
	local duration = 0.5

	local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)

	if open then
		local goalL = { CFrame = doorClosedL * CFrame.new(0, 0, -offset) }
		local goalR = { CFrame = doorClosedR * CFrame.new(0, 0, offset) }
		local tweenL = TweenService:Create(doorL, tweenInfo, goalL)
		local tweenR = TweenService:Create(doorR, tweenInfo, goalR)
		tweenL:Play()
		tweenR:Play()
	else
		local goalL = { CFrame = doorClosedL }
		local goalR = { CFrame = doorClosedR }
		local tweenL = TweenService:Create(doorL, tweenInfo, goalL)
		local tweenR = TweenService:Create(doorR, tweenInfo, goalR)
		tweenL:Play()
		tweenR:Play()
	end

	local elevator = findElevator()
	if elevator then
		local name = open and "DoorOpen" or "DoorClose"
		local s = elevator:FindFirstChild(name)
		if s and s:IsA("Sound") then
			s:Play()
			task.delay(0.6, function()
				s:Stop()
			end)
		end

	end
end

local function updateDisplay(text)
	local elevator = findElevator()
	if not elevator then return end

	local textSurface = elevator:FindFirstChild("FloorTextSurface")
	if not textSurface then return end

	local sg = textSurface:FindFirstChildOfClass("SurfaceGui")
	if not sg then return end

	local label = sg:FindFirstChild("FloorNumber")
	if label then
		label.Text = text
	end
end

local function addResultsScreen(floor)
	local screen = Instance.new("Part")
	screen.Name = "ResultsScreen"
	screen.Size = Vector3.new(26, 14, 0.3)
	screen.CFrame = CFrame.new(-21, 7.5, 8.3)
	screen.Anchored = true
	screen.Locked = false
	screen.Color = Color3.fromRGB(8, 8, 12)
	screen.Material = Enum.Material.SmoothPlastic
	screen.Parent = floor

	local sg = Instance.new("SurfaceGui")
	sg.Name = "ResultsGui"
	sg.Face = Enum.NormalId.Front
	sg.AlwaysOnTop = false
	sg.ResetOnSpawn = false
	sg.CanvasSize = Vector2.new(600, 340)
	sg.Parent = screen

	local title = Instance.new("TextLabel")
	title.Name = "Title"
	title.Size = UDim2.new(1, -40, 0, 34)
	title.Position = UDim2.new(0, 20, 0, 12)
	title.BackgroundTransparency = 1
	title.TextColor3 = Color3.fromRGB(255, 220, 100)
	title.Text = ""
	title.TextScaled = true
	title.TextXAlignment = Enum.TextXAlignment.Center
	title.TextYAlignment = Enum.TextYAlignment.Center
	title.Font = Enum.Font.GothamBold
	title.Parent = sg

	local sub = Instance.new("TextLabel")
	sub.Name = "Subtitle"
	sub.Size = UDim2.new(1, -40, 0, 18)
	sub.Position = UDim2.new(0, 20, 0, 50)
	sub.BackgroundTransparency = 1
	sub.TextColor3 = Color3.fromRGB(180, 180, 200)
	sub.Text = ""
	sub.TextScaled = true
	sub.TextXAlignment = Enum.TextXAlignment.Left
	sub.TextYAlignment = Enum.TextYAlignment.Center
	sub.Font = Enum.Font.GothamBold
	sub.Visible = false
	sub.Parent = sg

	local body = Instance.new("TextLabel")
	body.Name = "Body"
	body.Size = UDim2.new(1, -40, 0, 90)
	body.Position = UDim2.new(0, 20, 0, 72)
	body.BackgroundTransparency = 1
	body.TextColor3 = Color3.fromRGB(200, 200, 210)
	body.Text = ""
	body.TextScaled = true
	body.TextXAlignment = Enum.TextXAlignment.Left
	body.TextYAlignment = Enum.TextYAlignment.Top
	body.Font = Enum.Font.Gotham
	body.Visible = false
	body.Parent = sg

	local timer = Instance.new("TextLabel")
	timer.Name = "Timer"
	timer.Size = UDim2.new(0, 70, 0, 44)
	timer.Position = UDim2.new(0.5, -35, 1, -56)
	timer.BackgroundTransparency = 1
	timer.TextColor3 = Color3.fromRGB(255, 255, 255)
	timer.Text = ""
	timer.TextScaled = true
	timer.TextXAlignment = Enum.TextXAlignment.Center
	timer.TextYAlignment = Enum.TextYAlignment.Center
	timer.Font = Enum.Font.GothamBlack
	timer.Visible = false
	timer.Parent = sg

	local resBody = Instance.new("TextLabel")
	resBody.Name = "ResultsBody"
	resBody.Size = UDim2.new(1, -40, 1, -55)
	resBody.Position = UDim2.new(0, 20, 0, 50)
	resBody.BackgroundTransparency = 1
	resBody.TextColor3 = Color3.fromRGB(200, 200, 210)
	resBody.Text = ""
	resBody.TextScaled = true
	resBody.TextXAlignment = Enum.TextXAlignment.Left
	resBody.TextYAlignment = Enum.TextYAlignment.Top
	resBody.Font = Enum.Font.Gotham
	resBody.Visible = false
	resBody.Parent = sg

	return screen
end

local function showPhase(screen, title, subtitle, body, timerSeconds)
	local sg = screen:FindFirstChild("ResultsGui")
	if not sg then return end

	local tl = sg:FindFirstChild("Title")
	local st = sg:FindFirstChild("Subtitle")
	local bd = sg:FindFirstChild("Body")
	local tm = sg:FindFirstChild("Timer")
	local rb = sg:FindFirstChild("ResultsBody")

	if tl then tl.Text = title end
	if st then st.Text = subtitle or ""; st.Visible = subtitle ~= nil end
	if bd then bd.Text = body or ""; bd.Visible = body ~= nil end
	if tm then tm.Text = timerSeconds and tostring(timerSeconds) or ""; tm.Visible = timerSeconds ~= nil end
	if rb then rb.Visible = false end
end

local function showResultsOnScreen(screen, results, anomalyName)
	local sg = screen:FindFirstChild("ResultsGui")
	if not sg then return end

	-- Clear previous widgets
	local oldBox = sg:FindFirstChild("RevealHeadshotBox")
	if oldBox then oldBox:Destroy() end
	local oldPodium = sg:FindFirstChild("PodiumFrame")
	if oldPodium then oldPodium:Destroy() end

	sg:FindFirstChild("Title").Text = "ROUND RESULTS"
	sg:FindFirstChild("Subtitle").Visible = false
	sg:FindFirstChild("Body").Visible = false
	sg:FindFirstChild("Timer").Visible = false

	local rb = sg:FindFirstChild("ResultsBody")
	rb.Visible = false

	-- Top 3 podium
	local sorted = {}
	for _, r in ipairs(results) do
		table.insert(sorted, r)
	end
	table.sort(sorted, function(a, b) return (a.total or 0) > (b.total or 0) end)

	local podiumFrame = Instance.new("Frame")
	podiumFrame.Name = "PodiumFrame"
	podiumFrame.Size = UDim2.new(1, -40, 0, 110)
	podiumFrame.Position = UDim2.new(0, 20, 0, 78)
	podiumFrame.BackgroundTransparency = 1
	podiumFrame.Parent = sg

	local podiumColors = {
		Color3.fromRGB(255, 215, 0),
		Color3.fromRGB(192, 192, 192),
		Color3.fromRGB(205, 127, 50),
	}

	for i = 1, math.min(3, #sorted) do
		local r = sorted[i]
		local heights = { 0.75, 0.5, 0.35 }
		local h = heights[i]

		local col = podiumColors[i]

		local block = Instance.new("Frame")
		block.Size = UDim2.new(0, 70, 0, 40 + 40 * h)
		block.Position = UDim2.new(0.5, -105 + (i - 1) * 105, 1, -10 - 40 * h)
		block.AnchorPoint = Vector2.new(0, 1)
		block.BackgroundColor3 = col
		block.BackgroundTransparency = 0.3
		block.BorderSizePixel = 0
		block.Parent = podiumFrame

		local medal = Instance.new("TextLabel")
		medal.Size = UDim2.new(1, 0, 0, 18)
		medal.Position = UDim2.new(0, 0, 0, 4)
		medal.BackgroundTransparency = 1
		medal.TextColor3 = Color3.fromRGB(255, 255, 255)
		medal.TextScaled = true
		medal.Font = Enum.Font.GothamBold
		medal.TextXAlignment = Enum.TextXAlignment.Center
		if i == 1 then medal.Text = "#1"
		elseif i == 2 then medal.Text = "#2"
		else medal.Text = "#3" end
		medal.Parent = block

		local nameLabel = Instance.new("TextLabel")
		nameLabel.Size = UDim2.new(1, -8, 0, 18)
		nameLabel.Position = UDim2.new(0, 4, 0, 22)
		nameLabel.BackgroundTransparency = 1
		nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
		nameLabel.TextScaled = true
		nameLabel.Font = Enum.Font.GothamBold
		nameLabel.TextXAlignment = Enum.TextXAlignment.Center
		nameLabel.Text = r.name
		nameLabel.Parent = block

		local scoreLabel = Instance.new("TextLabel")
		scoreLabel.Size = UDim2.new(1, -8, 0, 16)
		scoreLabel.Position = UDim2.new(0, 4, 0, 42)
		scoreLabel.BackgroundTransparency = 1
		scoreLabel.TextColor3 = Color3.fromRGB(255, 255, 200)
		scoreLabel.TextScaled = true
		scoreLabel.Font = Enum.Font.Gotham
		scoreLabel.TextXAlignment = Enum.TextXAlignment.Center
		scoreLabel.Text = tostring(r.total) .. " pts"
		scoreLabel.Parent = block
	end

	-- Anomaly label at top
	local anomalyLabel = sg:FindFirstChild("AnomalyLabel")
	if not anomalyLabel then
		anomalyLabel = Instance.new("TextLabel")
		anomalyLabel.Name = "AnomalyLabel"
		anomalyLabel.Size = UDim2.new(1, -40, 0, 24)
		anomalyLabel.Position = UDim2.new(0, 20, 0, 50)
		anomalyLabel.BackgroundTransparency = 1
		anomalyLabel.TextColor3 = Color3.fromRGB(255, 220, 100)
		anomalyLabel.TextScaled = true
		anomalyLabel.TextXAlignment = Enum.TextXAlignment.Center
		anomalyLabel.Font = Enum.Font.GothamBold
		anomalyLabel.Parent = sg
	end
	anomalyLabel.Visible = true
	anomalyLabel.Text = "ANOMALY: " .. (anomalyName or "None")

	-- Headshot box at bottom
	local box = Instance.new("Frame")
	box.Name = "RevealHeadshotBox"
	box.Size = UDim2.new(1, -20, 0, 100)
	box.Position = UDim2.new(0, 10, 1, -115)
	box.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
	box.BackgroundTransparency = 0.25
	box.BorderSizePixel = 0
	box.Parent = sg

	local cellSize = 60
	local totalW = #results * (cellSize + 8) - 8
	local startX = math.max(0, (600 - 20 - totalW) / 2)

	for i, r in ipairs(results) do
		local x = startX + (i - 1) * (cellSize + 8)

		local borderColor
		if r.correct then
			borderColor = Color3.fromRGB(80, 255, 80)
		elseif r.noAnomaly then
			borderColor = Color3.fromRGB(255, 220, 100)
		elseif r.abstained then
			borderColor = Color3.fromRGB(140, 140, 140)
		else
			borderColor = Color3.fromRGB(255, 60, 60)
		end

		local border = Instance.new("Frame")
		border.Size = UDim2.new(0, cellSize, 0, cellSize)
		border.Position = UDim2.new(0, x, 0, 6)
		border.BackgroundColor3 = borderColor
		border.BorderSizePixel = 0
		border.Parent = box

		local img = Instance.new("ImageLabel")
		img.Size = UDim2.new(1, -4, 1, -4)
		img.Position = UDim2.new(0, 2, 0, 2)
		img.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
		img.BorderSizePixel = 0
		img.Parent = border

		local nameLabel = Instance.new("TextLabel")
		nameLabel.Size = UDim2.new(0, cellSize + 8, 0, 14)
		nameLabel.Position = UDim2.new(0, -4, 0, cellSize + 2)
		nameLabel.BackgroundTransparency = 1
		nameLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
		nameLabel.TextScaled = true
		nameLabel.TextXAlignment = Enum.TextXAlignment.Center
		nameLabel.Font = Enum.Font.Gotham
		nameLabel.Text = r.name
		nameLabel.Parent = border

		local ptsLabel = Instance.new("TextLabel")
		ptsLabel.Size = UDim2.new(0, cellSize + 8, 0, 12)
		ptsLabel.Position = UDim2.new(0, -4, 0, cellSize + 16)
		ptsLabel.BackgroundTransparency = 1
		ptsLabel.TextColor3 = borderColor
		ptsLabel.TextScaled = true
		ptsLabel.TextXAlignment = Enum.TextXAlignment.Center
		ptsLabel.Font = Enum.Font.GothamBold
		if r.correct then
			ptsLabel.Text = "+" .. r.points .. " (" .. r.total .. ")"
		elseif r.noAnomaly then
			ptsLabel.Text = "+" .. r.points .. " (" .. r.total .. ")"
		elseif r.abstained then
			ptsLabel.Text = "—"
		else
			ptsLabel.Text = r.points .. " (" .. r.total .. ")"
		end
		ptsLabel.Parent = border

		task.spawn(function()
			local ok, url = pcall(function()
				return Players:GetUserThumbnailAsync(r.userId, Enum.ThumbnailType.AvatarBust, Enum.ThumbnailSize.Size420x420)
			end)
			if ok then
				img.Image = url
			end
		end)
	end
end

local function findSpawnPoint()
	local lobby = Workspace:FindFirstChild("Lobby")
	if lobby then
		local spawn = lobby:FindFirstChildOfClass("SpawnLocation")
		if spawn then
			return spawn.CFrame + Vector3.new(0, 3, 0)
		end
	end
	return CFrame.new(0, 1003, 0)
end

local function teleportToElevator(player)
	local elevator = findElevator()
	if not elevator then return end
	local target = elevator:FindFirstChild("TeleportTarget")
	if not target then return end
	local char = player.Character
	if char and char:FindFirstChild("HumanoidRootPart") then
		char.HumanoidRootPart.CFrame = target.CFrame + Vector3.new(0, 3, 0)
	end
end

local function teleportToLobby(player)
	local cf = findSpawnPoint()
	local char = player.Character
	if char and char:FindFirstChild("HumanoidRootPart") then
		char.HumanoidRootPart.CFrame = cf
	end
end

local function teleportToElevatorLobby(player)
	local char = player.Character
	if char and char:FindFirstChild("HumanoidRootPart") then
		char.HumanoidRootPart.CFrame = CFrame.lookAt(
			Vector3.new(-21, 3, 2),
			Vector3.new(-21, 3, 9)
		)
	end
end

local function returnAllPlayers(players)
	for _, player in ipairs(players) do
		teleportToLobby(player)
	end
	local lobbyMusic = game:GetService("SoundService"):FindFirstChild("LobbyMusic")
	if lobbyMusic then lobbyMusic:Play() end
end

local function runChatPhase(players, guesses, guessNames, anomalyName, floorNum, screen)
	setDoors(false)

	-- Place players in the elevator lobby
	for _, player in ipairs(players) do
		teleportToElevatorLobby(player)
	end

	-- Block the doorway between elevator lobby and hallway
	local floor = Workspace:FindFirstChild("Floor")
	local barrier = nil
	if floor then
		barrier = Instance.new("Part")
		barrier.Name = "ChatBarrier"
		barrier.Size = Vector3.new(18, 15, 1)
		barrier.CFrame = CFrame.new(-21, 7.5, -27)
		barrier.Anchored = true
		barrier.Locked = false
		barrier.CanCollide = true
		barrier.Transparency = 0.6
		barrier.Color = Color3.fromRGB(60, 60, 70)
		barrier.Material = Enum.Material.Metal
		barrier.Parent = floor
	end

	-- Aggregate unique guessed names from the search phase
	local pool = {}
	for userId, name in pairs(guessNames) do
		pool[name] = true
	end
	local options = {}
	for name, _ in pairs(pool) do
		table.insert(options, name)
	end

	local lockedIn = {}
	local totalActive = 0
	for _, player in ipairs(players) do
		if player.Parent then
			totalActive += 1
		end
	end

	local remaining = CHAT_TIME
	local chatActive = true
	local sg = screen:FindFirstChild("ResultsGui")
	local headshotWidgets = {}

	local chatConnection
	chatConnection = Remotes.LogGuess.OnServerEvent:Connect(function(player, objectName)
		if not chatActive then return end
		if lockedIn[player.UserId] then return end

		if objectName == "NoAnomaly" then
			guesses[player.UserId] = "noAnomaly"
		else
			guesses[player.UserId] = (objectName == anomalyName)
		end
		guessNames[player.UserId] = objectName
		Remotes.LogGuess:FireClient(player, "updated")
	end)

	local lockConnection
	lockConnection = Remotes.LockInGuess.OnServerEvent:Connect(function(player)
		if not chatActive then return end
		if lockedIn[player.UserId] then return end
		lockedIn[player.UserId] = true

		local headshotWidget = headshotWidgets[player.UserId]
		if headshotWidget then
			headshotWidget.BackgroundColor3 = Color3.fromRGB(80, 255, 80)
		end

		local allLocked = 0
		for _, p in ipairs(players) do
			if p.Parent and lockedIn[p.UserId] then
				allLocked += 1
			end
		end
		if allLocked >= totalActive and remaining > 3 then
			remaining = 3
		end
	end)

	-- Set up headshots on the wall screen — box at bottom, text stays above
	if sg then
		local tm = sg:FindFirstChild("Timer")
		if tm then tm.Visible = false end

		local box = Instance.new("Frame")
		box.Name = "ChatHeadshotBox"
		box.Size = UDim2.new(1, -20, 0, 80)
		box.Position = UDim2.new(0, 10, 1, -95)
		box.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
		box.BackgroundTransparency = 0.3
		box.BorderSizePixel = 0
		box.Parent = sg

		local cellSize = 52
		local totalW = #players * (cellSize + 6) - 6
		local startX = math.max(0, (600 - 20 - totalW) / 2)

		for i, player in ipairs(players) do
			local x = startX + (i - 1) * (cellSize + 6)

			local border = Instance.new("Frame")
			border.Name = "HS_" .. player.UserId
			border.Size = UDim2.new(0, cellSize, 0, cellSize)
			border.Position = UDim2.new(0, x, 0, 6)
			border.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
			border.BorderSizePixel = 0
			border.Parent = box

			local img = Instance.new("ImageLabel")
			img.Size = UDim2.new(1, -4, 1, -4)
			img.Position = UDim2.new(0, 2, 0, 2)
			img.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
			img.BorderSizePixel = 0
			img.Parent = border

			local nameLabel = Instance.new("TextLabel")
			nameLabel.Size = UDim2.new(0, cellSize + 8, 0, 14)
			nameLabel.Position = UDim2.new(0, -4, 0, cellSize + 2)
			nameLabel.BackgroundTransparency = 1
			nameLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
			nameLabel.TextScaled = true
			nameLabel.TextXAlignment = Enum.TextXAlignment.Center
			nameLabel.Font = Enum.Font.Gotham
			nameLabel.Text = player.Name
			nameLabel.Parent = border

			headshotWidgets[player.UserId] = border

			task.spawn(function()
				local ok, url = pcall(function()
					return Players:GetUserThumbnailAsync(player.UserId, Enum.ThumbnailType.AvatarBust, Enum.ThumbnailSize.Size420x420)
				end)
				if ok then
					img.Image = url
				end
			end)
		end
	end

	for _, player in ipairs(players) do
		Remotes.RoundChatStart:FireClient(player, {
			options = options,
			currentGuess = guessNames[player.UserId],
		})
	end

	remaining = CHAT_TIME
	while remaining > 0 do
		Remotes.RoundTimerTick:FireAllClients(remaining, "chat")
		showPhase(screen, "FLOOR " .. floorNum,
			"— DISCUSSION —",
			"Talk it over with the group.\nNot sure? You can swap your pick to anything another player found.\nLock it in when you're ready.",
			nil)
		task.wait(1)
		remaining -= 1
	end

	chatActive = false
	chatConnection:Disconnect()
	lockConnection:Disconnect()

	-- Remove headshot box
	if sg then
		local box = sg:FindFirstChild("ChatHeadshotBox")
		if box then box:Destroy() end
	end

	-- Remove barrier
	if barrier then
		barrier:Destroy()
	end
end

local function scoreAndReveal(players, guesses, guessNames, guessTimes, anomalyName, floorNum, screen, includeBoarding, playersRef)
	local results = {}
	for _, player in ipairs(players) do
		local guess = guesses[player.UserId]
		local correct = (guess == true)
		local abstained = (guess == nil)
		local noAnomaly = (guess == "noAnomaly") and (anomalyName == nil)
		local time = guessTimes[player.UserId]

		local points = 0
		if correct then
			points = 10
		elseif noAnomaly then
			points = 5
		elseif not abstained then
			points = -5
		end

		scores[player.UserId] = (scores[player.UserId] or 0) + points
		table.insert(results, {
			name = player.Name,
			userId = player.UserId,
			correct = correct,
			abstained = abstained,
			noAnomaly = noAnomaly,
			points = points,
			total = scores[player.UserId],
			time = time,
		})
		LeaderboardService.updateStats(player, correct, abstained)
	end

	showResultsOnScreen(screen, results, anomalyName)
	Remotes.RevealResults:FireAllClients(results)

	-- Highlight the anomaly object with a yellow outline during reveal
	if anomalyName then
		local floor = Workspace:FindFirstChild("Floor")
		local anomalyFolder = floor and floor:FindFirstChild("Anomaly")
		local anomalyObj = anomalyFolder and anomalyFolder:FindFirstChild(anomalyName)
		if anomalyObj then
			local highlight = Instance.new("Highlight")
			highlight.Adornee = anomalyObj
			highlight.FillColor = Color3.fromRGB(255, 220, 50)
			highlight.FillTransparency = 0.6
			highlight.OutlineColor = Color3.fromRGB(255, 200, 0)
			highlight.OutlineTransparency = 0
			highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
			highlight.Parent = anomalyObj
		end
	end

	task.wait(REVEAL_TIME)

	for _, r in ipairs(results) do
		print(r.name .. ": " .. r.points .. " (" .. r.total .. " total)")
	end

	if includeBoarding then
		updateDisplay("▲")
		setDoors(true)
		startElevatorMusic()
		for i = BOARDING_TIME, 1, -1 do
			Remotes.RoundTimerTick:FireAllClients(i, "boarding")
			showPhase(screen, "BOARDING", nil, "Elevator doors are open.\nStep inside for the next floor.", i)
			task.wait(1)
		end

		for _, player in ipairs(players) do
			teleportToElevator(player)
		end
		setDoors(false)
	end
end

local function spawnAndRun(players, floorNum, anomalyName, doAnomalySwap, includeBoarding)
	local floor = FloorCloner.spawnFloor()
	if not floor then return end
	local screen = addResultsScreen(floor)

	-- Going up + anomaly swap
	updateDisplay("▲\nto Floor " .. floorNum)
	for i = GOING_UP_TIME, 1, -1 do
		Remotes.RoundTimerTick:FireAllClients(i, "goingUp")
		showPhase(screen, "GOING UP", nil, "Something changed while you weren't looking...", i)
		if i == GOING_UP_TIME and doAnomalySwap then
			anomalyName = AnomalySwapper.swapAnomaly()
		end
		if i == 1 then
			playDing()
		end
		task.wait(1)
	end

	-- Search
	setDoors(true)
	updateDisplay(tostring(floorNum))
	local guesses = {}
	local guessNames = {}
	local guessTimes = {}
	local guessCount = 0
	local totalPlayers = #players
	local searchActive = true
	local remaining = SEARCH_TIME

	for _, player in ipairs(players) do
		guesses[player.UserId] = nil
	end

	local connection
	connection = Remotes.LogGuess.OnServerEvent:Connect(function(player, objectName)
		if not searchActive then return end
		if guesses[player.UserId] ~= nil then return end

		if objectName == "NoAnomaly" then
			guesses[player.UserId] = "noAnomaly"
			guessNames[player.UserId] = "NoAnomaly"
			guessTimes[player.UserId] = SEARCH_TIME - remaining
			guessCount += 1
			Remotes.LogGuess:FireClient(player, "logged")
			return
		end

		if not anomalyName then return end

		local correct = (objectName == anomalyName)
		guesses[player.UserId] = correct
		guessNames[player.UserId] = objectName
		guessTimes[player.UserId] = SEARCH_TIME - remaining
		guessCount += 1
		Remotes.LogGuess:FireClient(player, correct and "correct" or "wrong")
	end)

	while remaining > 0 and guessCount < totalPlayers do
		Remotes.RoundTimerTick:FireAllClients(remaining, "search")
		showPhase(screen, "FLOOR " .. floorNum,
			"FIND THE ANOMALY",
			"Use your magnifying glass to investigate the rooms.\nClick on what you believe is the anomaly.",
			remaining)
		task.wait(1)
		remaining -= 1
	end

	searchActive = false
	connection:Disconnect()

	-- Chat phase
	runChatPhase(players, guesses, guessNames, anomalyName, floorNum, screen)

	-- Scoring + Reveal
	scoreAndReveal(players, guesses, guessNames, guessTimes, anomalyName, floorNum, screen, includeBoarding)

	AnomalySwapper.revertAll()
	floor:Destroy()
	Remotes.FloorReset:FireAllClients()
end

local function Start(players)
	print("Round started with " .. #players .. " players")
	AnomalySwapper.resetUsed()
	cacheDoorPositions()

	-- === ROUND 0: Explore (floor 0) + First anomaly (floor 1) ===
	local floor = FloorCloner.spawnFloor()
	if not floor then return end
	local screen = addResultsScreen(floor)

	-- Arriving at floor 0
	updateDisplay("0")
	showPhase(screen, "FLOOR 0", nil, "Arriving...", nil)
	task.wait(1.5)
	playDing()
	task.wait(0.3)
	setDoors(true)
	for i = EXPLORE_TIME, 1, -1 do
		Remotes.RoundTimerTick:FireAllClients(i, "explore")
		showPhase(screen, "FLOOR 0",
			"OBJECTIVE",
			"Learn your environment.\nThings may or may not change on the next floor.",
			i)
		task.wait(1)
	end

	for _, player in ipairs(players) do
		teleportToElevator(player)
	end
	setDoors(false)
	startElevatorMusic()

	-- Going up + swap first anomaly
	updateDisplay("▲\nto Floor 1")
	local anomalyNameFloor1
	for i = GOING_UP_TIME, 1, -1 do
		Remotes.RoundTimerTick:FireAllClients(i, "goingUp")
		showPhase(screen, "GOING UP", nil, "Something changed while you weren't looking...", i)
		if i == GOING_UP_TIME then
			anomalyNameFloor1 = AnomalySwapper.swapAnomaly()
		end
		if i == 1 then
			playDing()
		end
		task.wait(1)
	end

	-- Search floor 1 (first anomaly)
	setDoors(true)
	updateDisplay("1")
	local guesses = {}
	local guessNames = {}
	local guessTimes = {}
	local guessCount = 0
	local totalPlayers = #players
	local searchActive = true
	local remaining = SEARCH_TIME

	for _, player in ipairs(players) do
		guesses[player.UserId] = nil
	end

	local connection
	connection = Remotes.LogGuess.OnServerEvent:Connect(function(player, objectName)
		if not searchActive then return end
		if guesses[player.UserId] ~= nil then return end

		if objectName == "NoAnomaly" then
			guesses[player.UserId] = "noAnomaly"
			guessNames[player.UserId] = "NoAnomaly"
			guessTimes[player.UserId] = SEARCH_TIME - remaining
			guessCount += 1
			Remotes.LogGuess:FireClient(player, "logged")
			return
		end

		local correct = (objectName == anomalyNameFloor1)
		guesses[player.UserId] = correct
		guessNames[player.UserId] = objectName
		guessTimes[player.UserId] = SEARCH_TIME - remaining
		guessCount += 1
		Remotes.LogGuess:FireClient(player, correct and "correct" or "wrong")
	end)

	while remaining > 0 and guessCount < totalPlayers do
		Remotes.RoundTimerTick:FireAllClients(remaining, "search")
		showPhase(screen, "FLOOR 1",
			"FIND THE ANOMALY",
			"Use your magnifying glass to investigate the rooms.\nClick on what you believe is the anomaly.",
			remaining)
		task.wait(1)
		remaining -= 1
	end

	searchActive = false
	connection:Disconnect()

	-- Chat phase for floor 1
	runChatPhase(players, guesses, guessNames, anomalyNameFloor1, 1, screen)

	-- Scoring + Reveal floor 1
	local resultsFloor1 = {}
	for _, player in ipairs(players) do
		local guess = guesses[player.UserId]
		local correct = (guess == true)
		local abstained = (guess == nil)
		local noAnomaly = (guess == "noAnomaly") and (anomalyNameFloor1 == nil)
		local time = guessTimes[player.UserId]

		local points = 0
		if correct then points = 10
		elseif noAnomaly then points = 5
		elseif not abstained then points = -5 end

		scores[player.UserId] = (scores[player.UserId] or 0) + points
		table.insert(resultsFloor1, {
			name = player.Name, userId = player.UserId, correct = correct, abstained = abstained,
			noAnomaly = noAnomaly, points = points, total = scores[player.UserId],
			time = time,
		})
		LeaderboardService.updateStats(player, correct, abstained)
	end

	for _, player in ipairs(players) do
		teleportToElevatorLobby(player)
	end

	showResultsOnScreen(screen, resultsFloor1, anomalyNameFloor1)
	Remotes.RevealResults:FireAllClients(resultsFloor1)

	if anomalyNameFloor1 then
		local anomalyFolder = floor and floor:FindFirstChild("Anomaly")
		local anomalyObj = anomalyFolder and anomalyFolder:FindFirstChild(anomalyNameFloor1)
		if anomalyObj then
			local h = Instance.new("Highlight")
			h.Adornee = anomalyObj
			h.FillColor = Color3.fromRGB(255, 220, 50)
			h.FillTransparency = 0.6
			h.OutlineColor = Color3.fromRGB(255, 200, 0)
			h.OutlineTransparency = 0
			h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
			h.Parent = anomalyObj
		end
	end

	task.wait(REVEAL_TIME)

	for _, r in ipairs(resultsFloor1) do
		print(r.name .. ": " .. r.points .. " (" .. r.total .. " total)")
	end

	-- Boarding → destroy floor 0/1
	updateDisplay("▲")
	setDoors(true)
	startElevatorMusic()
	for i = BOARDING_TIME, 1, -1 do
		Remotes.RoundTimerTick:FireAllClients(i, "boarding")
		showPhase(screen, "BOARDING", nil, "Elevator doors are open.\nStep inside for the next floor.", i)
		task.wait(1)
	end

	for _, player in ipairs(players) do
		teleportToElevator(player)
	end
	setDoors(false)

	AnomalySwapper.revertAll()
	floor:Destroy()
	Remotes.FloorReset:FireAllClients()

	-- === ROUND 2 (floor 2): fresh build ===
	spawnAndRun(players, 2, nil, true, true)

	-- === ROUND 3 (floor 3): fresh build, last ===
	spawnAndRun(players, 3, nil, true, false)

	-- Done
	updateDisplay("0")
	returnAllPlayers(players)
	print("All floors completed. Players returned to lobby.")
end

return { Start = Start }
]]></string>
