      <Item class="ModuleScript" referent="16">
        <Properties>
          <string name="Name">ElevatorGenerator</string>
          <string name="Source"><![CDATA[-- ElevatorGenerator.luau
-- Run from Command Bar: loadstring(game.ReplicatedStorage.Tools.ElevatorGenerator.Source)()
-- Builds the elevator model in Workspace. Persistent hub, never destroyed.

local DW = 22
local DD = 18
local DH = 15
local T = 0.5

local WC = Color3.fromRGB(170, 140, 100)
local FC = Color3.fromRGB(40, 35, 30)
local CC = Color3.fromRGB(240, 240, 235)
local MC = Color3.fromRGB(200, 175, 120)
local DC = Color3.fromRGB(160, 150, 140)

local function part(name, size, cf, color, mat, trans)
	local o = Instance.new("Part")
	o.Name = name
	o.Size = size
	o.CFrame = cf
	o.Color = color
	o.Material = mat or Enum.Material.Plastic
	o.Anchored = true
	o.Locked = false
	o.Transparency = trans or 0
	return o
end

local elevator = Instance.new("Model")
elevator.Name = "Elevator"
elevator.Parent = workspace

-- Floor
local floor = part("Floor", Vector3.new(DD, 0.5, DW),
	CFrame.new(0, 0, 0), FC, Enum.Material.Fabric)
floor.Parent = elevator

-- Teleport target (where players land when round starts)
local spawn = part("TeleportTarget", Vector3.new(4, 0.5, 4),
	CFrame.new(0, 0.5, 0), Color3.fromRGB(100, 200, 100), Enum.Material.Plastic, 0.8)
spawn.Parent = elevator

-- Ceiling
local ceiling = part("Ceiling", Vector3.new(DD, 0.3, DW),
	CFrame.new(0, DH, 0), CC)
ceiling.Parent = elevator

-- Back wall (xMin, wood paneling)
local backWall = part("BackWall", Vector3.new(T, DH, DW),
	CFrame.new(-DD/2, DH/2, 0), WC, Enum.Material.Wood)
backWall.Parent = elevator

-- Left wall (zMin, wood paneling)
local leftWall = part("LeftWall", Vector3.new(DD, DH, T),
	CFrame.new(0, DH/2, -DW/2), WC, Enum.Material.Wood)
leftWall.Parent = elevator

-- Right wall (zMax, wood paneling)
local rightWall = part("RightWall", Vector3.new(DD, DH, T),
	CFrame.new(0, DH/2, DW/2), WC, Enum.Material.Wood)
rightWall.Parent = elevator

-- Brass handrails along side walls
local railL = part("Handrail_L", Vector3.new(DD - 1, 0.15, 0.15),
	CFrame.new(0, 4.5, -DW/2 + 0.5), MC, Enum.Material.Metal)
railL.Parent = elevator

local railR = part("Handrail_R", Vector3.new(DD - 1, 0.15, 0.15),
	CFrame.new(0, 4.5, DW/2 - 0.5), MC, Enum.Material.Metal)
railR.Parent = elevator

-- Two sliding metal doors (front wall, xMax side)
-- Door opening spans 20 of 22 studs (1 stud frame each side)
-- Left door: z=-10 to 0, Right door: z=0 to 10
local doorH = 13
local doorY = 0
local doorX = DD/2
local doorHalfW = 10
local doorGap = 0.1

local doorL = part("Door_Left", Vector3.new(0.2, doorH, doorHalfW),
	CFrame.new(doorX, doorY + doorH/2, -doorHalfW/2), DC, Enum.Material.Metal)
doorL.Parent = elevator

local doorR = part("Door_Right", Vector3.new(0.2, doorH, doorHalfW),
	CFrame.new(doorX, doorY + doorH/2, doorHalfW/2), DC, Enum.Material.Metal)
doorR.Parent = elevator

-- Door frame
local frameW = DW - doorHalfW * 2
local frameThick = 0.3

local frameLeft = part("DoorFrame_L", Vector3.new(0.4, doorH, frameThick),
	CFrame.new(doorX, doorY + doorH/2, -DW/2 + frameThick/2), Color3.fromRGB(120, 110, 100), Enum.Material.Metal)
frameLeft.Parent = elevator

local frameRight = part("DoorFrame_R", Vector3.new(0.4, doorH, frameThick),
	CFrame.new(doorX, doorY + doorH/2, DW/2 - frameThick/2), Color3.fromRGB(120, 110, 100), Enum.Material.Metal)
frameRight.Parent = elevator

local frameTop = part("DoorFrame_T", Vector3.new(0.4, frameThick, DW - 1),
	CFrame.new(doorX, doorY + doorH + frameThick/2, 0), Color3.fromRGB(120, 110, 100), Enum.Material.Metal)
frameTop.Parent = elevator

-- Wall above doors
local aboveDoor = part("AboveDoor", Vector3.new(T, DH - doorY - doorH, DW),
	CFrame.new(doorX, doorY + doorH + (DH - doorY - doorH)/2, 0), WC, Enum.Material.Wood)
aboveDoor.Parent = elevator

-- Floor number display on back wall
local displayW = 7
local displayH = 5
local displayFrame = part("FloorDisplay", Vector3.new(0.1, displayH, displayW),
	CFrame.new(-DD/2 + 0.3, DH * 0.55, 0),
	Color3.fromRGB(10, 10, 10), Enum.Material.Plastic)
displayFrame.Parent = elevator

-- Invisible backing with larger surface for the text
local textSurface = part("FloorTextSurface", Vector3.new(0.1, 12, 16),
	CFrame.new(-DD/2 + 0.6, DH * 0.55, 0),
	Color3.fromRGB(0, 0, 0), Enum.Material.Plastic, 1)
textSurface.Parent = elevator

local sg = Instance.new("SurfaceGui")
sg.Face = Enum.NormalId.Right
sg.AlwaysOnTop = false
sg.ResetOnSpawn = false
sg.Parent = textSurface

local label = Instance.new("TextLabel")
label.Name = "FloorNumber"
label.Size = UDim2.new(1, 0, 1, 0)
label.BackgroundTransparency = 1
label.TextColor3 = Color3.fromRGB(0, 255, 100)
label.TextScaled = true
label.Font = Enum.Font.GothamBold
label.Text = "0"
label.Parent = sg

-- Dim yellow light in center of ceiling
local lightPart = part("LightFixture", Vector3.new(1, 0.2, 1),
	CFrame.new(0, DH - 0.3, 0), Color3.fromRGB(255, 240, 200))
lightPart.Parent = elevator

local pointLight = Instance.new("PointLight")
pointLight.Color = Color3.fromRGB(255, 220, 150)
pointLight.Brightness = 1.5
pointLight.Range = 20
pointLight.Shadows = true
pointLight.Parent = lightPart

-- Ambient hum placeholder (add real SoundId later)

-- Position the elevator at the elevator lobby opening on the game floor
-- Elevator lobby zMin wall is at z=-27 (after floor centering), opening x=-30..-12
-- Elevator rotated 90° so doors face +Z toward the lobby opening
local OFFSET = CFrame.new(-46.1, 0, -9)
for _, child in elevator:GetChildren() do
	if child:IsA("BasePart") then
		child.CFrame = OFFSET * child.CFrame
	end
end

-- Clone to ServerStorage.Templates.Elevator
local templates = game.ServerStorage.Templates
local existing = templates:FindFirstChild("Elevator")
if existing then existing:Destroy() end
local saved = elevator:Clone()
saved.Name = "Elevator"
saved.Parent = templates

print("Elevator built in Workspace and saved to ServerStorage.Templates.Elevator.")
return true
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="17">
        <Properties>
          <string name="Name">FloorGenerator</string>
          <string name="Source"><![CDATA[-- FloorGenerator.luau
-- Run from Command Bar: loadstring(game.ReplicatedStorage.Tools.FloorGenerator.Source)()

local H = 15
local T = 1
local BH = 1.5
local CC = Color3.fromRGB(255, 255, 255)
local BC = Color3.fromRGB(200, 190, 175)
local DC = Color3.fromRGB(160, 120, 80)
local LC = Color3.fromRGB(255, 245, 230)

local function part(name, size, cf, color, mat, trans)
	local o = Instance.new("Part")
	o.Name = name
	o.Size = size
	o.CFrame = cf
	o.Color = color
	o.Material = mat or Enum.Material.Plastic
	o.Anchored = true
	o.Locked = false
	o.Transparency = trans or 0
	return o
end

local function addRoomLabel(ceiling, roomName)
	local sg = Instance.new("SurfaceGui")
	sg.Face = Enum.NormalId.Bottom
	sg.AlwaysOnTop = true
	sg.ResetOnSpawn = false
	sg.Parent = ceiling
	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.TextColor3 = Color3.fromRGB(200, 200, 200)
	label.TextScaled = true
	label.Font = Enum.Font.GothamBold
	label.Text = roomName
	label.Parent = sg
end

-- Rooms: {name, xMin, xMax, zMin, zMax, floorColor, floorMat, wallColor, wallMat}
local WALL_TINTS = {
	Hallway = Color3.fromRGB(240, 235, 225),
	ElevatorLobby = Color3.fromRGB(235, 230, 220),
	LivingRoom = Color3.fromRGB(245, 235, 220),
	Kitchen = Color3.fromRGB(240, 240, 235),
	Bedroom = Color3.fromRGB(235, 230, 225),
	Bathroom = Color3.fromRGB(230, 235, 240),
}

local rooms = {
	{ "Hallway", 0, 72, 0, 24, Color3.fromRGB(180, 140, 100), Enum.Material.Wood },
	{ "ElevatorLobby", 0, 30, 24, 60, Color3.fromRGB(200, 190, 175), Enum.Material.Slate },
	{ "LivingRoom", 30, 72, 24, 84, Color3.fromRGB(170, 130, 85), Enum.Material.Wood },
	{ "Kitchen", 30, 66, 84, 132, Color3.fromRGB(210, 200, 190), Enum.Material.Granite },
	{ "Bedroom", 0, 36, -30, 0, Color3.fromRGB(155, 145, 140), Enum.Material.Carpet },
	{ "Bathroom", 42, 72, -24, 0, Color3.fromRGB(215, 210, 205), Enum.Material.Slate },
}

local cutouts = {
	{ "ElevatorLobby", "zMin", 6, 24 },
	{ "Hallway", "zMax", 6, 24 },
	{ "Hallway", "zMax", 32, 50 },
	{ "LivingRoom", "zMin", 32, 50 },
	{ "LivingRoom", "zMax", 32, 50 },
	{ "Kitchen", "zMin", 32, 50 },
	{ "Hallway", "zMin", 12, 24 },
	{ "Bedroom", "zMax", 12, 24 },
	{ "Hallway", "zMin", 48, 60 },
	{ "Bathroom", "zMax", 48, 60 },
	{ "ElevatorLobby", "xMin", 32, 52 },
}

local cutoutsByRoom = {}
for _, r in ipairs(rooms) do
	cutoutsByRoom[r[1]] = {}
end
for _, c in ipairs(cutouts) do
	local roomName, side, a, b = unpack(c)
	if not cutoutsByRoom[roomName] then cutoutsByRoom[roomName] = {} end
	if not cutoutsByRoom[roomName][side] then cutoutsByRoom[roomName][side] = {} end
	table.insert(cutoutsByRoom[roomName][side], { a, b })
end

local floorModel = Instance.new("Folder")
floorModel.Name = "CurrentFloor"
floorModel.Parent = workspace

-- Floors and ceilings
for _, r in ipairs(rooms) do
	local name, xMin, xMax, zMin, zMax, flColor, flMat = unpack(r)
	local w = xMax - xMin
	local d = zMax - zMin
	local cx = (xMin + xMax) / 2
	local cz = (zMin + zMax) / 2

	local fl = part(name.."_Floor", Vector3.new(w, 1, d),
		CFrame.new(cx, 0, cz), flColor, flMat)
	fl.Parent = floorModel

	local cl = part(name.."_Ceiling", Vector3.new(w, 1, d),
		CFrame.new(cx, H, cz), CC)
	cl.Parent = floorModel
	addRoomLabel(cl, name)
end

-- Walls + baseboards + crown molding
local function makeWalls(name, xMin, xMax, zMin, zMax, side)
	local totalStart, totalEnd, fixedPos, isHorizontal
	if side == "zMin" or side == "zMax" then
		totalStart = xMin; totalEnd = xMax
		fixedPos = (side == "zMin") and zMin or zMax
		isHorizontal = true
	else
		totalStart = zMin; totalEnd = zMax
		fixedPos = (side == "xMin") and xMin or xMax
		isHorizontal = false
	end

	local openings = {}
	if cutoutsByRoom[name] and cutoutsByRoom[name][side] then
		openings = cutoutsByRoom[name][side]
	end
	table.sort(openings, function(a, b) return a[1] < b[1] end)

	local segments = {}
	local cursor = totalStart
	for _, gap in ipairs(openings) do
		local gs, ge = gap[1], gap[2]
		if cursor < gs then
			table.insert(segments, { cursor, gs })
		end
		cursor = math.max(cursor, ge)
	end
	if cursor < totalEnd then
		table.insert(segments, { cursor, totalEnd })
	end

	local wallColor = WALL_TINTS[name] or WC

	for _, seg in ipairs(segments) do
		local segStart, segEnd = seg[1], seg[2]
		local segSize = segEnd - segStart
		local segCenter = (segStart + segEnd) / 2

		local wallPart
		if isHorizontal then
			wallPart = part(name.."_W_"..side.."_"..segStart,
				Vector3.new(segSize, H, T),
				CFrame.new(segCenter, H/2, fixedPos), wallColor, Enum.Material.SmoothPlastic)
		else
			wallPart = part(name.."_W_"..side.."_"..segStart,
				Vector3.new(T, H, segSize),
				CFrame.new(fixedPos, H/2, segCenter), wallColor, Enum.Material.SmoothPlastic)
		end
		wallPart.Parent = floorModel

		-- Baseboard at bottom
		local basePart
		if isHorizontal then
			basePart = part(name.."_Base_"..side.."_"..segStart,
				Vector3.new(segSize, BH, T + 0.3),
				CFrame.new(segCenter, BH/2, fixedPos), BC, Enum.Material.Wood)
		else
			basePart = part(name.."_Base_"..side.."_"..segStart,
				Vector3.new(T + 0.3, BH, segSize),
				CFrame.new(fixedPos, BH/2, segCenter), BC, Enum.Material.Wood)
		end
		basePart.Parent = floorModel

		-- Crown molding at top
		local crownPart
		if isHorizontal then
			crownPart = part(name.."_Crown_"..side.."_"..segStart,
				Vector3.new(segSize, BH, T + 0.3),
				CFrame.new(segCenter, H - BH/2, fixedPos), BC, Enum.Material.Wood)
		else
			crownPart = part(name.."_Crown_"..side.."_"..segStart,
				Vector3.new(T + 0.3, BH, segSize),
				CFrame.new(fixedPos, H - BH/2, segCenter), BC, Enum.Material.Wood)
		end
		crownPart.Parent = floorModel
	end
end

for _, r in ipairs(rooms) do
	local name, xMin, xMax, zMin, zMax = unpack(r)
	makeWalls(name, xMin, xMax, zMin, zMax, "xMin")
	makeWalls(name, xMin, xMax, zMin, zMax, "xMax")
	makeWalls(name, xMin, xMax, zMin, zMax, "zMin")
	makeWalls(name, xMin, xMax, zMin, zMax, "zMax")
end


-- Ceiling light fixtures per room
for _, r in ipairs(rooms) do
	local name, xMin, xMax, zMin, zMax = unpack(r)
	local cx = (xMin + xMax) / 2
	local cz = (zMin + zMax) / 2

	local lightFixture = part(name.."_Light", Vector3.new(2, 0.3, 2),
		CFrame.new(cx, H - 0.5, cz), LC, Enum.Material.Plastic)
	lightFixture.Parent = floorModel

	local pointLight = Instance.new("PointLight")
	pointLight.Color = Color3.fromRGB(255, 240, 210)
	pointLight.Brightness = 0.8
	pointLight.Range = 40
	pointLight.Shadows = false
	pointLight.Parent = lightFixture
end

-- Window at hallway dead end (xMax wall at x=72)
-- The window frame extrudes 0.5 studs too far into the room
local winW = 10
local winH = 8
local winY = 4
local winZ = 12

-- Wall inner face is at x=71.5, outer face at x=72.5
-- Frame sits from x=71.0 to x=72.0 (0.5 past inner face, 0.5 into wall)
local fDepth = 1.0
local fThick = 0.4

-- Glass centered at wall inner face
local glass = part("HallwayWindow_Glass", Vector3.new(0.3, winH, winW),
	CFrame.new(71.5, winY + winH/2, winZ),
	Color3.fromRGB(180, 210, 255), Enum.Material.Glass, 0.3)
glass.Parent = floorModel

-- Frame extrudes inward 0.5 past inner wall face
local frameX = 71.5
local frameLeft = part("HallwayWindow_Frame_L", Vector3.new(fDepth, winH + fThick*2, fThick),
	CFrame.new(frameX, winY + winH/2, winZ - winW/2 - fThick/2),
	Color3.fromRGB(220, 210, 190), Enum.Material.Wood)
frameLeft.Parent = floorModel

local frameRight = part("HallwayWindow_Frame_R", Vector3.new(fDepth, winH + fThick*2, fThick),
	CFrame.new(frameX, winY + winH/2, winZ + winW/2 + fThick/2),
	Color3.fromRGB(220, 210, 190), Enum.Material.Wood)
frameRight.Parent = floorModel

local frameTop = part("HallwayWindow_Frame_T", Vector3.new(fDepth, fThick, winW + fThick*2),
	CFrame.new(frameX, winY + winH + fThick/2, winZ),
	Color3.fromRGB(220, 210, 190), Enum.Material.Wood)
frameTop.Parent = floorModel

local frameBot = part("HallwayWindow_Frame_B", Vector3.new(fDepth, fThick, winW + fThick*2),
	CFrame.new(frameX, winY - fThick/2, winZ),
	Color3.fromRGB(220, 210, 190), Enum.Material.Wood)
frameBot.Parent = floorModel

-- Sill extruding past inner face
local sill = part("HallwayWindow_Sill", Vector3.new(1.3, 0.4, winW + 1.5),
	CFrame.new(frameX, winY - 0.2, winZ),
	Color3.fromRGB(200, 190, 175), Enum.Material.Wood)
sill.Parent = floorModel

-- Set warm ambient lighting so rooms aren't dark between fixtures
local lighting = game:GetService("Lighting")
lighting.Ambient = Color3.fromRGB(60, 55, 50)
lighting.Brightness = 0.5
lighting.OutdoorAmbient = Color3.fromRGB(60, 55, 50)
lighting.ClockTime = 14

-- Center the floor
local minX, maxX, minZ, maxZ = math.huge, -math.huge, math.huge, -math.huge
for _, child in floorModel:GetChildren() do
	if child:IsA("BasePart") then
		local c = child.Position
		local s = child.Size / 2
		minX = math.min(minX, c.X - s.X)
		maxX = math.max(maxX, c.X + s.X)
		minZ = math.min(minZ, c.Z - s.Z)
		maxZ = math.max(maxZ, c.Z + s.Z)
	end
end
local centerX = (minX + maxX) / 2
local centerZ = (minZ + maxZ) / 2
for _, child in floorModel:GetChildren() do
	if child:IsA("BasePart") then
		local pos = child.Position
		child.CFrame = CFrame.new(pos.X - centerX, pos.Y, pos.Z - centerZ) * child.CFrame.Rotation
	end
end

-- Clone to ServerStorage.Templates.MasterFloor (keep workspace copy)
local templates = game.ServerStorage.Templates
local existing = templates:FindFirstChild("MasterFloor")
if existing then existing:Destroy() end
local master = Instance.new("Model")
master.Name = "MasterFloor"
local saved = floorModel:Clone()
saved.Name = "Floor"
saved.Parent = master
master.Parent = templates

floorModel.Name = "Floor"

print("Floor built in Workspace and saved to ServerStorage.Templates.MasterFloor.")
return true
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="18">
        <Properties>
          <string name="Name">LobbyGenerator</string>
          <string name="Source"><![CDATA[-- LobbyGenerator.luau
-- Builds the hotel lobby at Y=1000 with an open elevator bay for matchmaking.

local function part(name, size, cf, color, mat)
	local o = Instance.new("Part")
	o.Name = name
	o.Size = size
	o.CFrame = cf
	o.Color = color
	o.Material = mat or Enum.Material.Plastic
	o.Anchored = true
	o.Locked = false
	return o
end

local LOBBY = workspace
local Y = 1000
local W = 60
local D = 40
local H = 15
local T = 1

local WC = Color3.fromRGB(220, 210, 195)
local FC = Color3.fromRGB(200, 185, 165)
local CC = Color3.fromRGB(245, 240, 235)
local BC = Color3.fromRGB(70, 65, 60)

local lobby = Instance.new("Model")
lobby.Name = "Lobby"
lobby.Parent = LOBBY

-- Floor
local floor = part("Floor", Vector3.new(W, 0.5, D), CFrame.new(0, Y, 0), FC, Enum.Material.Marble)
floor.Parent = lobby

-- Ceiling
local ceil = part("Ceiling", Vector3.new(W, 0.3, D), CFrame.new(0, Y + H, 0), CC)
ceil.Parent = lobby

-- Back wall (zMin) — solid
local backWall = part("Wall_Back", Vector3.new(W, H, T), CFrame.new(0, Y + H/2, -D/2), WC)
backWall.Parent = lobby

-- Left wall (xMin) — solid
local leftWall = part("Wall_Left", Vector3.new(T, H, D), CFrame.new(-W/2, Y + H/2, 0), WC)
leftWall.Parent = lobby

-- Right wall (xMax) — solid
local rightWall = part("Wall_Right", Vector3.new(T, H, D), CFrame.new(W/2, Y + H/2, 0), WC)
rightWall.Parent = lobby

-- Front wall (zMax) — three segments with a 16-stud opening for the bay
local bayW = 16
local frontZ = D/2

-- Left segment: from x=-W/2 to x=-bayW/2
local segLeft = part("Wall_Front_L", Vector3.new((W - bayW) / 2, H, T),
	CFrame.new(-(W + bayW) / 4, Y + H/2, frontZ), WC)
segLeft.Parent = lobby

-- Right segment: from x=bayW/2 to x=W/2
local segRight = part("Wall_Front_R", Vector3.new((W - bayW) / 2, H, T),
	CFrame.new((W + bayW) / 4, Y + H/2, frontZ), WC)
segRight.Parent = lobby

-- Top segment: above the bay opening
local segTop = part("Wall_Front_T", Vector3.new(bayW, H - 14, T),
	CFrame.new(0, Y + (H + 14) / 2, frontZ), WC)
segTop.Parent = lobby

-- Bay floor (slightly raised, different material to mark the zone)
local bayFloor = part("BayFloor", Vector3.new(bayW - 2, 0.2, 6),
	CFrame.new(0, Y + 0.35, frontZ - 3), Color3.fromRGB(60, 55, 50), Enum.Material.Slate)
bayFloor.Parent = lobby

-- Door frame around the bay opening (metal trim)
local fT = 0.5
local frameL = part("BayFrame_L", Vector3.new(0.8, 14, 0.8),
	CFrame.new(-bayW/2, Y + 7.5, frontZ), BC, Enum.Material.Metal)
frameL.Parent = lobby

local frameR = part("BayFrame_R", Vector3.new(0.8, 14, 0.8),
	CFrame.new(bayW/2, Y + 7.5, frontZ), BC, Enum.Material.Metal)
frameR.Parent = lobby

local frameT = part("BayFrame_T", Vector3.new(bayW + 1.6, 0.8, 0.8),
	CFrame.new(0, Y + 14.4, frontZ), BC, Enum.Material.Metal)
frameT.Parent = lobby

-- Elevator bay room (extends outward from the opening)
local bayDepth = 8
local bayHeight = 14
local bayY = Y + 1

-- Bay floor
local bayFloorOuter = part("BayFloor_Outer", Vector3.new(bayW, 0.3, bayDepth),
	CFrame.new(0, bayY, frontZ + bayDepth/2), Color3.fromRGB(40, 35, 30), Enum.Material.Fabric)
bayFloorOuter.Parent = lobby

-- Bay side walls
local bayWallL = part("BayWall_L", Vector3.new(0.5, bayHeight, bayDepth),
	CFrame.new(-bayW/2, bayY + bayHeight/2, frontZ + bayDepth/2), Color3.fromRGB(170, 140, 100), Enum.Material.Wood)
bayWallL.Parent = lobby

local bayWallR = part("BayWall_R", Vector3.new(0.5, bayHeight, bayDepth),
	CFrame.new(bayW/2, bayY + bayHeight/2, frontZ + bayDepth/2), Color3.fromRGB(170, 140, 100), Enum.Material.Wood)
bayWallR.Parent = lobby

-- Bay ceiling
local bayCeil = part("BayCeiling", Vector3.new(bayW, 0.3, bayDepth),
	CFrame.new(0, bayY + bayHeight, frontZ + bayDepth/2), CC)
bayCeil.Parent = lobby

-- Bay back wall (inner side, faces the lobby opening)
local bayBack = part("BayBack", Vector3.new(bayW - 1, bayHeight, 0.3),
	CFrame.new(0, bayY + bayHeight/2, frontZ + bayDepth), Color3.fromRGB(170, 140, 100), Enum.Material.Wood)
bayBack.Parent = lobby

-- Bay light
local bayLight = part("BayLight", Vector3.new(1, 0.2, 1),
	CFrame.new(0, bayY + bayHeight - 0.5, frontZ + bayDepth/2), Color3.fromRGB(255, 240, 200))
bayLight.Parent = lobby

local bpl = Instance.new("PointLight")
bpl.Color = Color3.fromRGB(255, 220, 150)
bpl.Brightness = 1.5
bpl.Range = 12
bpl.Shadows = true
bpl.Parent = bayLight

-- Overhead sign inside the bay
local innerSign = part("BayInnerSign", Vector3.new(bayW - 2, 1.5, 0.2),
	CFrame.new(0, bayY + bayHeight - 2, frontZ + bayDepth - 0.5), Color3.fromRGB(30, 30, 30))
innerSign.Parent = lobby

local isg = Instance.new("SurfaceGui")
isg.Face = Enum.NormalId.Front
isg.AlwaysOnTop = true
isg.ResetOnSpawn = false
isg.Parent = innerSign

local ilabel = Instance.new("TextLabel")
ilabel.Size = UDim2.new(1, 0, 1, 0)
ilabel.BackgroundTransparency = 1
ilabel.TextColor3 = Color3.fromRGB(255, 220, 50)
ilabel.TextScaled = true
ilabel.Font = Enum.Font.GothamBold
ilabel.Text = "ELEVATOR BAY"
ilabel.Parent = isg

-- Countdown sign above the bay opening (lobby side)
local sign = part("BaySign", Vector3.new(bayW, 2, 0.3),
	CFrame.new(0, Y + 15.5, frontZ - 0.5), Color3.fromRGB(30, 30, 30))
sign.Parent = lobby

local sg = Instance.new("SurfaceGui")
sg.Face = Enum.NormalId.Back
sg.AlwaysOnTop = true
sg.ResetOnSpawn = false
sg.Parent = sign

local label = Instance.new("TextLabel")
label.Name = "Countdown"
label.Size = UDim2.new(1, 0, 0.6, 0)
label.BackgroundTransparency = 1
label.TextColor3 = Color3.fromRGB(255, 220, 50)
label.TextScaled = true
label.Font = Enum.Font.GothamBold
label.Text = "WAITING"
label.Parent = sg

local sub = Instance.new("TextLabel")
sub.Name = "SubText"
sub.Size = UDim2.new(1, 0, 0.4, 0)
sub.Position = UDim2.new(0, 0, 0.6, 0)
sub.BackgroundTransparency = 1
sub.TextColor3 = Color3.fromRGB(200, 200, 200)
sub.TextScaled = true
sub.Font = Enum.Font.Gotham
sub.Text = "Max 8 Players"
sub.Parent = sg

-- Touch detector (invisible, inside the bay cab)
local detector = part("BayDetector", Vector3.new(bayW - 3, 3, bayDepth - 2),
	CFrame.new(0, Y + 1.5, frontZ + bayDepth/2), Color3.fromRGB(255, 0, 0))
detector.Transparency = 1
detector.CanCollide = false
detector.Parent = lobby

-- Spawn location
local spawn = Instance.new("SpawnLocation")
spawn.Name = "SpawnLocation"
spawn.Size = Vector3.new(4, 0.5, 4)
spawn.CFrame = CFrame.new(0, Y + 0.6, -10)
spawn.Anchored = true
spawn.Locked = false
spawn.Transparency = 0.5
spawn.BrickColor = BrickColor.new("Bright green")
spawn.Duration = 0
spawn.Parent = lobby

-- Light fixture
local light = part("Light", Vector3.new(2, 0.3, 2),
	CFrame.new(0, Y + H - 0.5, 0), Color3.fromRGB(255, 245, 230))
light.Parent = lobby

local pl = Instance.new("PointLight")
pl.Color = Color3.fromRGB(255, 230, 200)
pl.Brightness = 2
pl.Range = 40
pl.Shadows = true
pl.Parent = light

print("Lobby built at Y=" .. Y .. " with open elevator bay (16-stud opening, front wall cutout).")
print("Walk into the bay opening to queue. SpawnLocation at center of lobby.")
return true
]]></string>
        </Properties>
