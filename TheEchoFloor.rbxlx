        <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local Remotes = ReplicatedStorage.Remotes

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local isMobile = UserInputService.TouchEnabled

-- Root GUI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "ChatMenu"
screenGui.ResetOnSpawn = false
screenGui.Enabled = false
screenGui.Parent = playerGui

local clickSound = Instance.new("Sound")
clickSound.SoundId = "rbxassetid://1238528678"
clickSound.Volume = 0.5
clickSound.Parent = screenGui
if isMobile then
	screenGui.IgnoreGuiInset = true
end

if isMobile then
	local uiscale = Instance.new("UIScale")
	uiscale.Parent = screenGui
	local function updateScale()
		local camera = workspace.CurrentCamera
		if camera then
			local sz = camera.ViewportSize
			local s = math.min(sz.X / 1920, sz.Y / 1080)
			uiscale.Scale = math.clamp(s, 0.35, 2)
		end
	end
	updateScale()
	workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
		updateScale()
		local cam = workspace.CurrentCamera
		if cam then
			cam:GetPropertyChangedSignal("ViewportSize"):Connect(updateScale)
		end
	end)
end

-- Change Guess button (bottom-left)
local changeBtn = Instance.new("TextButton")
changeBtn.Name = "ChangeGuessBtn"
changeBtn.Size = UDim2.new(0, 180, 0, 36)
changeBtn.Position = UDim2.new(0, 15, 1, -50)
changeBtn.AnchorPoint = Vector2.new(0, 1)
changeBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
changeBtn.BorderColor3 = Color3.fromRGB(255, 220, 50)
changeBtn.BorderSizePixel = 1
changeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
changeBtn.TextScaled = true
changeBtn.Font = Enum.Font.Gotham
changeBtn.Text = "Change Guess"
changeBtn.Visible = false
changeBtn.Parent = screenGui

-- Current guess label (centered above buttons)
local guessLabel = Instance.new("TextLabel")
guessLabel.Name = "GuessLabel"
guessLabel.Size = UDim2.new(0, 300, 0, 24)
guessLabel.Position = UDim2.new(0.5, -150, 1, -100)
guessLabel.BackgroundTransparency = 1
guessLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
guessLabel.TextScaled = true
guessLabel.TextXAlignment = Enum.TextXAlignment.Center
guessLabel.Font = Enum.Font.Gotham
guessLabel.Text = "Your guess: None"
guessLabel.Visible = false
guessLabel.Parent = screenGui

-- Lock In button (bottom-right)
local lockBtn = Instance.new("TextButton")
lockBtn.Name = "LockInBtn"
lockBtn.Size = UDim2.new(0, 160, 0, 36)
lockBtn.Position = UDim2.new(1, -15, 1, -50)
lockBtn.AnchorPoint = Vector2.new(1, 1)
lockBtn.BackgroundColor3 = Color3.fromRGB(60, 160, 60)
lockBtn.BorderSizePixel = 0
lockBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
lockBtn.TextScaled = true
lockBtn.Font = Enum.Font.GothamBold
lockBtn.Text = "Lock In"
lockBtn.Visible = false
lockBtn.Parent = screenGui

-- Popup overlay (hidden by default)
local popupOverlay = Instance.new("Frame")
popupOverlay.Name = "PopupOverlay"
popupOverlay.Size = UDim2.new(1, 0, 1, 0)
popupOverlay.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
popupOverlay.BackgroundTransparency = 0.5
popupOverlay.Visible = false
popupOverlay.Parent = screenGui

local popupFrame = Instance.new("Frame")
popupFrame.Name = "PopupFrame"
popupFrame.Size = UDim2.new(0, 360, 0, 300)
popupFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
popupFrame.AnchorPoint = Vector2.new(0.5, 0.5)
popupFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
popupFrame.BorderColor3 = Color3.fromRGB(255, 220, 50)
popupFrame.BorderSizePixel = 2
popupFrame.Parent = popupOverlay

local popupTitle = Instance.new("TextLabel")
popupTitle.Name = "Title"
popupTitle.Size = UDim2.new(1, -40, 0, 36)
popupTitle.Position = UDim2.new(0, 20, 0, 10)
popupTitle.BackgroundTransparency = 1
popupTitle.TextColor3 = Color3.fromRGB(255, 220, 50)
popupTitle.TextScaled = true
popupTitle.Font = Enum.Font.GothamBold
popupTitle.Text = "Change Your Guess"
popupTitle.Parent = popupFrame

local popupList = Instance.new("ScrollingFrame")
popupList.Name = "OptionList"
popupList.Size = UDim2.new(1, -20, 1, -95)
popupList.Position = UDim2.new(0, 10, 0, 50)
popupList.BackgroundTransparency = 1
popupList.BorderSizePixel = 0
popupList.ScrollBarThickness = 4
popupList.CanvasSize = UDim2.new(0, 0, 0, 0)
popupList.Parent = popupFrame

local popupCancel = Instance.new("TextButton")
popupCancel.Name = "CancelBtn"
popupCancel.Size = UDim2.new(0, 120, 0, 32)
popupCancel.Position = UDim2.new(0.5, -60, 1, -14)
popupCancel.AnchorPoint = Vector2.new(0.5, 1)
popupCancel.BackgroundColor3 = Color3.fromRGB(80, 80, 85)
popupCancel.TextColor3 = Color3.fromRGB(255, 255, 255)
popupCancel.TextScaled = true
popupCancel.Font = Enum.Font.Gotham
popupCancel.Text = "Cancel"
popupCancel.Parent = popupFrame

-- State
local options = {}
local lockedIn = false
local currentSelection = nil

local function closePopup()
	popupOverlay.Visible = false
end

local function selectOption(name)
	if lockedIn then return end
	Remotes.LogGuess:FireServer(name)
	currentSelection = name
	closePopup()
end

local function openPopup()
	if lockedIn then return end
	-- Clear old options
	for _, child in ipairs(popupList:GetChildren()) do
		if child:IsA("TextButton") then child:Destroy() end
	end

	local sorted = {}
	for _, name in ipairs(options) do
		table.insert(sorted, name)
	end
	table.sort(sorted)

	local rowSize = 38
	local rowPad = 4
	local topPad = 4
	local totalH = #sorted * (rowSize + rowPad) - rowPad + topPad * 2
	popupList.CanvasSize = UDim2.new(0, 0, 0, math.max(totalH, popupList.AbsoluteSize.Y))

	-- Top spacer
	local spacer = Instance.new("Frame")
	spacer.Size = UDim2.new(1, 0, 0, topPad)
	spacer.BackgroundTransparency = 1
	spacer.Parent = popupList

	for i, name in ipairs(sorted) do
		local isSel = (name == currentSelection)
		local btn = Instance.new("TextButton")
		btn.Name = name
		btn.Size = UDim2.new(1, -10, 0, rowSize)
		btn.Position = UDim2.new(0, 5, 0, topPad + (i - 1) * (rowSize + rowPad))
		btn.BackgroundColor3 = isSel and Color3.fromRGB(60, 160, 60) or Color3.fromRGB(50, 50, 55)
		btn.BorderSizePixel = 0
		btn.Text = ""
		btn.Parent = popupList

		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1, -10, 1, 0)
		label.Position = UDim2.new(0, 8, 0, 0)
		label.BackgroundTransparency = 1
		label.TextColor3 = isSel and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(200, 200, 200)
		label.TextScaled = true
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.Font = isSel and Enum.Font.GothamBold or Enum.Font.Gotham
		label.Text = name
		label.Parent = btn

		if isSel then
			local check = Instance.new("TextLabel")
			check.Size = UDim2.new(0, 18, 0, 18)
			check.Position = UDim2.new(1, -22, 0.5, -9)
			check.BackgroundTransparency = 1
			check.TextColor3 = Color3.fromRGB(80, 255, 80)
			check.TextScaled = true
			check.Font = Enum.Font.GothamBold
			check.Text = "✓"
			check.Parent = btn
		end

		btn.MouseButton1Click:Connect(function()
			selectOption(name)
		end)
	end

	popupOverlay.Visible = true
end

changeBtn.MouseButton1Click:Connect(openPopup)
popupCancel.MouseButton1Click:Connect(closePopup)

lockBtn.MouseButton1Click:Connect(function()
	if lockedIn then return end
	lockedIn = true
	Remotes.LockInGuess:FireServer()
	lockBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
	lockBtn.Text = "Locked In ✓"
	lockBtn.TextColor3 = Color3.fromRGB(180, 255, 180)
	changeBtn.Visible = false
	clickSound:Play()
end)

-- Remote handlers
Remotes.RoundChatStart.OnClientEvent:Connect(function(data)
	screenGui.Enabled = true
	currentSelection = data.currentGuess
	options = data.options or {}
	lockedIn = false
	changeBtn.Visible = true
	lockBtn.Visible = true
	guessLabel.Visible = true
	guessLabel.Text = "Your guess: " .. (data.currentGuess or "None")
	lockBtn.BackgroundColor3 = Color3.fromRGB(60, 160, 60)
	lockBtn.Text = "Lock In"
	lockBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	closePopup()
end)

Remotes.RevealResults.OnClientEvent:Connect(function()
	screenGui.Enabled = false
	guessLabel.Visible = false
	closePopup()
end)

Remotes.RoundStart.OnClientEvent:Connect(function()
	screenGui.Enabled = false
	guessLabel.Visible = false
	closePopup()
end)

Remotes.FloorReset.OnClientEvent:Connect(function()
	screenGui.Enabled = false
	guessLabel.Visible = false
	closePopup()
end)
]]></string>
      </Properties>
    </Item>
    <Item class="LocalScript" referent="32">
      <Properties>
        <string name="Name">QueueUI</string>
        <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Remotes = ReplicatedStorage.Remotes

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local isMobile = UserInputService.TouchEnabled

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "QueueUI"
screenGui.ResetOnSpawn = false
screenGui.Enabled = false
if isMobile then
	screenGui.IgnoreGuiInset = true
end
screenGui.Parent = playerGui

if isMobile then
	local uiscale = Instance.new("UIScale")
	uiscale.Parent = screenGui
	local function updateScale()
		local camera = workspace.CurrentCamera
		if camera then
			local sz = camera.ViewportSize
			local s = math.min(sz.X / 1920, sz.Y / 1080)
			uiscale.Scale = math.clamp(s, 0.35, 2)
		end
	end
	updateScale()
	workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
		updateScale()
		local cam = workspace.CurrentCamera
		if cam then
			cam:GetPropertyChangedSignal("ViewportSize"):Connect(updateScale)
		end
	end)
end

local timerLabel = Instance.new("TextLabel")
timerLabel.Name = "Timer"
timerLabel.Size = UDim2.fromOffset(300, 80)
timerLabel.Position = UDim2.new(0.5, 0, 0, 30)
timerLabel.AnchorPoint = Vector2.new(0.5, 0)
timerLabel.BackgroundTransparency = 1
timerLabel.TextColor3 = Color3.fromRGB(255, 220, 50)
timerLabel.TextScaled = true
timerLabel.Font = Enum.Font.GothamBold
timerLabel.Text = ""
timerLabel.ZIndex = 10
timerLabel.Parent = screenGui

local subText = Instance.new("TextLabel")
subText.Name = "SubText"
subText.Size = UDim2.fromOffset(400, 40)
subText.Position = UDim2.new(0.5, 0, 0, 110)
subText.AnchorPoint = Vector2.new(0.5, 0)
subText.BackgroundTransparency = 1
subText.TextColor3 = Color3.fromRGB(200, 200, 200)
subText.TextScaled = true
subText.Font = Enum.Font.Gotham
subText.Text = ""
subText.ZIndex = 10
subText.Parent = screenGui

local countLabel = Instance.new("TextLabel")
countLabel.Name = "PlayerCount"
countLabel.Size = UDim2.fromOffset(300, 40)
countLabel.Position = UDim2.new(0.5, 0, 0, 160)
countLabel.AnchorPoint = Vector2.new(0.5, 0)
countLabel.BackgroundTransparency = 1
countLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
countLabel.TextScaled = true
countLabel.Font = Enum.Font.Gotham
countLabel.Text = ""
countLabel.ZIndex = 10
countLabel.Parent = screenGui

local exitButton = Instance.new("TextButton")
exitButton.Name = "ExitButton"
exitButton.Size = UDim2.fromOffset(200, 60)
exitButton.Position = UDim2.new(0.5, 0, 1, -80)
exitButton.AnchorPoint = Vector2.new(0.5, 1)
exitButton.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
exitButton.BackgroundTransparency = 0.3
exitButton.TextColor3 = Color3.fromRGB(255, 255, 255)
exitButton.TextScaled = true
exitButton.Font = Enum.Font.GothamBold
exitButton.Text = "LEAVE QUEUE"
exitButton.ZIndex = 10
exitButton.Parent = screenGui

exitButton.MouseButton1Click:Connect(function()
	Remotes.QueueExit:FireServer()
end)

Remotes.QueueUpdate.OnClientEvent:Connect(function(data)
	screenGui.Enabled = data.show
	if data.show then
		timerLabel.Text = tostring(data.seconds)
		countLabel.Text = data.count .. "/8 players"
		if data.seconds <= 5 then
			timerLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
			subText.Text = "Departing..."
		else
			timerLabel.TextColor3 = Color3.fromRGB(255, 220, 50)
			subText.Text = "Searching for players..."
		end
	end
end)

Remotes.RoundStart.OnClientEvent:Connect(function()
	screenGui.Enabled = false
end)
]]></string>
      </Properties>
    </Item>
    <Item class="LocalScript" referent="33">
      <Properties>
        <string name="Name">TimerHUD</string>
        <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local Remotes = ReplicatedStorage.Remotes

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local isMobile = UserInputService.TouchEnabled

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "TimerHUD"
screenGui.ResetOnSpawn = false
screenGui.Enabled = false
if isMobile then
	screenGui.IgnoreGuiInset = true
end
screenGui.Parent = playerGui

if isMobile then
	local uiscale = Instance.new("UIScale")
	uiscale.Parent = screenGui
	local function updateScale()
		local camera = workspace.CurrentCamera
		if camera then
			local sz = camera.ViewportSize
			local s = math.min(sz.X / 1920, sz.Y / 1080)
			uiscale.Scale = math.clamp(s, 0.35, 2)
		end
	end
	updateScale()
	workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
		updateScale()
		local cam = workspace.CurrentCamera
		if cam then
			cam:GetPropertyChangedSignal("ViewportSize"):Connect(updateScale)
		end
	end)
end

-- Timer box (left)
local timerBox = Instance.new("Frame")
timerBox.Name = "TimerBox"
timerBox.Size = UDim2.new(0, 100, 0, 40)
timerBox.Position = UDim2.new(0, 15, 0, 10)
timerBox.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
timerBox.BackgroundTransparency = 0.4
timerBox.BorderSizePixel = 0
timerBox.Parent = screenGui

local timerLabel = Instance.new("TextLabel")
timerLabel.Name = "TimerLabel"
timerLabel.Size = UDim2.new(1, 0, 1, 0)
timerLabel.BackgroundTransparency = 1
timerLabel.TextColor3 = Color3.fromRGB(255, 220, 50)
timerLabel.TextScaled = true
timerLabel.TextXAlignment = Enum.TextXAlignment.Center
timerLabel.Font = Enum.Font.GothamBold
timerLabel.Text = ""
timerLabel.Parent = timerBox

-- Phase box (center)
local phaseBox = Instance.new("Frame")
phaseBox.Name = "PhaseBox"
phaseBox.Size = UDim2.new(0, 300, 0, 40)
phaseBox.Position = UDim2.new(0.5, -150, 0, 10)
phaseBox.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
phaseBox.BackgroundTransparency = 0.4
phaseBox.BorderSizePixel = 0
phaseBox.Parent = screenGui

local phaseLabel = Instance.new("TextLabel")
phaseLabel.Name = "PhaseLabel"
phaseLabel.Size = UDim2.new(1, 0, 1, 0)
phaseLabel.BackgroundTransparency = 1
phaseLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
phaseLabel.TextScaled = true
phaseLabel.TextXAlignment = Enum.TextXAlignment.Center
phaseLabel.Font = Enum.Font.Gotham
phaseLabel.Text = ""
phaseLabel.Parent = phaseBox

-- Personal result label (centered below phase box, visible during reveal)
local resultBox = Instance.new("Frame")
resultBox.Name = "ResultBox"
resultBox.Size = UDim2.new(0, 400, 0, 50)
resultBox.Position = UDim2.new(0.5, -200, 0, 65)
resultBox.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
resultBox.BackgroundTransparency = 0.4
resultBox.BorderSizePixel = 0
resultBox.Visible = false
resultBox.Parent = screenGui

local resultLabel = Instance.new("TextLabel")
resultLabel.Name = "ResultLabel"
resultLabel.Size = UDim2.new(1, -20, 1, 0)
resultLabel.Position = UDim2.new(0, 10, 0, 0)
resultLabel.BackgroundTransparency = 1
resultLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
resultLabel.TextScaled = true
resultLabel.TextXAlignment = Enum.TextXAlignment.Center
resultLabel.Font = Enum.Font.GothamBold
resultLabel.Text = ""
resultLabel.Parent = resultBox

Remotes.RoundTimerTick.OnClientEvent:Connect(function(seconds, phase)
	screenGui.Enabled = true
	resultBox.Visible = false

	if phase == "explore" then
		timerLabel.Text = tostring(seconds)
		timerLabel.TextColor3 = Color3.fromRGB(100, 200, 255)
		phaseLabel.Text = "Explore the floor"
	elseif phase == "goingUp" then
		timerLabel.Text = tostring(seconds)
		timerLabel.TextColor3 = Color3.fromRGB(255, 200, 50)
		phaseLabel.Text = "GOING UP"
	elseif phase == "search" then
		timerLabel.Text = tostring(seconds)
		phaseLabel.Text = "Find the Anomaly"
		if seconds <= 10 then
			timerLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
		else
			timerLabel.TextColor3 = Color3.fromRGB(255, 220, 50)
		end
	elseif phase == "chat" then
		timerLabel.Text = tostring(seconds)
		timerLabel.TextColor3 = Color3.fromRGB(180, 180, 255)
		phaseLabel.Text = "Discussion"
	elseif phase == "boarding" then
		timerLabel.Text = tostring(seconds)
		timerLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
		phaseLabel.Text = "Board the elevator"
	end
end)

Remotes.RoundStart.OnClientEvent:Connect(function()
	timerLabel.Text = ""
	phaseLabel.Text = ""
	screenGui.Enabled = false
end)

local answerRightSound = Instance.new("Sound")
answerRightSound.Name = "AnswerRight"
answerRightSound.SoundId = "rbxassetid://3450794184"
answerRightSound.Volume = 0.5
answerRightSound.Parent = screenGui

local errorSound = Instance.new("Sound")
errorSound.Name = "ErrorSound"
errorSound.SoundId = "rbxassetid://550209561"
errorSound.Volume = 0.5
errorSound.Parent = screenGui

Remotes.RevealResults.OnClientEvent:Connect(function(results)
	screenGui.Enabled = true
	timerLabel.Text = "ROUND OVER"
	timerLabel.TextColor3 = Color3.fromRGB(255, 220, 50)
	phaseLabel.Text = "Results"

	for _, r in ipairs(results) do
		if r.name == player.Name then
			if r.correct then
				resultLabel.Text = "CORRECT! +" .. r.points
				resultLabel.TextColor3 = Color3.fromRGB(80, 255, 80)
				answerRightSound:Play()
			elseif r.noAnomaly then
				resultLabel.Text = "No Anomaly — Correct! +" .. r.points
				resultLabel.TextColor3 = Color3.fromRGB(255, 220, 100)
				answerRightSound:Play()
			elseif r.abstained then
				resultLabel.Text = "You didn't guess"
				resultLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
				errorSound:Play()
			else
				resultLabel.Text = "WRONG! " .. r.points
				resultLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
				errorSound:Play()
			end
			resultBox.Visible = true
			break
		end
	end
end)

Remotes.FloorReset.OnClientEvent:Connect(function()
	screenGui.Enabled = false
	timerLabel.Text = ""
	phaseLabel.Text = ""
	resultBox.Visible = false
	resultLabel.Text = ""
end)
]]></string>
      </Properties>
    </Item>
    <Item class="LocalScript" referent="34">
      <Properties>
        <string name="Name">ToolManager</string>
        <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Remotes = ReplicatedStorage.Remotes

local isMobile = UserInputService.TouchEnabled

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local backpack = player:WaitForChild("Backpack")

local hasGuessed = false
local currentGuess = nil
local toolEquipped = false

local clickSound = Instance.new("Sound")
clickSound.SoundId = "rbxassetid://1238528678"
clickSound.Volume = 0.5
clickSound.Parent = playerGui

local hoveredObject = nil
local currentPhase = ""

local highlight = Instance.new("Highlight")
highlight.FillColor = Color3.fromRGB(255, 220, 50)
highlight.FillTransparency = 0.5
highlight.OutlineColor = Color3.fromRGB(255, 200, 0)
highlight.OutlineTransparency = 0
highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
highlight.Enabled = false
highlight.Parent = workspace

local hoverSound = Instance.new("Sound")
hoverSound.SoundId = "rbxassetid://1238528678"
hoverSound.Volume = 0.4
hoverSound.Parent = workspace

local function clearHighlight()
	if hoveredObject then
		highlight.Adornee = nil
		highlight.Enabled = false
		hoveredObject = nil
	end
end

local function setHighlight(obj)
	if not (obj:IsA("BasePart") or obj:IsA("Model")) then return end
	clearHighlight()
	hoveredObject = obj
	highlight.Adornee = obj
	highlight.Enabled = true
	hoverSound:Play()
end

local function isStructural(name)
	if name:find("_Floor$") then return true end
	if name:find("_Ceiling$") then return true end
	if name:find("_Light$") then return true end
	if name:find("_W_") then return true end
	if name:find("_Base_") then return true end
	if name:find("_Crown_") then return true end
	if name:find("HallwayWindow") then return true end
	if name:find("^Bay") then return true end
	return false
end

local function getFloorObject(target)
	local floor = workspace:FindFirstChild("Floor")
	if not floor then return nil end

	local isInFloor = false
	local check = target
	while check do
		if check == floor then
			isInFloor = true
			break
		end
		check = check.Parent
	end
	if not isInFloor then return nil end

	local floorObject = target
	while floorObject and floorObject.Parent ~= floor do
		floorObject = floorObject.Parent
	end
	if floorObject and floorObject.Parent == floor and floorObject.Name == "Anomaly" then
		local child = target
		while child and child.Parent ~= floorObject do
			child = child.Parent
		end
		if child then floorObject = child end
	end
	if not floorObject then return nil end

	if isStructural(floorObject.Name) then return nil end

	return floorObject
end

local function addUIScale(gui)
	if not isMobile then return end
	local scale = Instance.new("UIScale")
	scale.Parent = gui
	local function update()
		local camera = workspace.CurrentCamera
		if camera then
			local sz = camera.ViewportSize
			local s = math.min(sz.X / 1920, sz.Y / 1080)
			scale.Scale = math.clamp(s, 0.35, 2)
		end
	end
	update()
	local conn
	conn = workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
		if conn then conn:Disconnect() end
		update()
		local cam = workspace.CurrentCamera
		if cam then
			cam:GetPropertyChangedSignal("ViewportSize"):Connect(update)
		end
	end)
end

-- Guess display (above hotbar, bottom right)
local guessGui = Instance.new("ScreenGui")
guessGui.Name = "GuessDisplay"
guessGui.ResetOnSpawn = false
guessGui.Enabled = false
guessGui.Parent = playerGui
addUIScale(guessGui)

local guessLabel = Instance.new("TextLabel")
guessLabel.Name = "GuessLabel"
guessLabel.Size = UDim2.new(0, 280, 0, 36)
guessLabel.Position = UDim2.new(1, -295, 1, -55)
guessLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
guessLabel.BackgroundTransparency = 0.4
guessLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
guessLabel.TextScaled = true
guessLabel.TextXAlignment = Enum.TextXAlignment.Center
guessLabel.Font = Enum.Font.Gotham
guessLabel.Text = "Your Guess: None"
guessLabel.Parent = guessGui

-- Confirmation popup
local confirmGui = Instance.new("ScreenGui")
confirmGui.Name = "ConfirmPopup"
confirmGui.ResetOnSpawn = false
confirmGui.Enabled = false
confirmGui.Parent = playerGui
addUIScale(confirmGui)

local overlay = Instance.new("Frame")
overlay.Name = "Overlay"
overlay.Size = UDim2.new(1, 0, 1, 0)
overlay.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
overlay.BackgroundTransparency = 0.6
overlay.Parent = confirmGui

local popup = Instance.new("Frame")
popup.Name = "Popup"
popup.Size = UDim2.new(0, 400, 0, 180)
popup.Position = UDim2.new(0.5, 0, 0.5, 0)
popup.AnchorPoint = Vector2.new(0.5, 0.5)
popup.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
popup.BorderColor3 = Color3.fromRGB(255, 220, 50)
popup.BorderSizePixel = 2
popup.Parent = confirmGui

local popupTitle = Instance.new("TextLabel")
popupTitle.Name = "Title"
popupTitle.Size = UDim2.new(1, -40, 0, 50)
popupTitle.Position = UDim2.new(0, 20, 0, 15)
popupTitle.BackgroundTransparency = 1
popupTitle.TextColor3 = Color3.fromRGB(255, 220, 50)
popupTitle.TextScaled = true
popupTitle.Font = Enum.Font.GothamBold
popupTitle.Text = "Confirm your guess"
popupTitle.Parent = popup

local popupBody = Instance.new("TextLabel")
popupBody.Name = "Body"
popupBody.Size = UDim2.new(1, -40, 0, 50)
popupBody.Position = UDim2.new(0, 20, 0, 65)
popupBody.BackgroundTransparency = 1
popupBody.TextColor3 = Color3.fromRGB(200, 200, 200)
popupBody.TextScaled = true
popupBody.Font = Enum.Font.Gotham
popupBody.Text = ""
popupBody.Parent = popup

local cancelBtn = Instance.new("TextButton")
cancelBtn.Name = "Cancel"
cancelBtn.Size = UDim2.new(0, 140, 0, 40)
cancelBtn.Position = UDim2.new(0.5, -80, 1, -15)
cancelBtn.AnchorPoint = Vector2.new(0.5, 1)
cancelBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 85)
cancelBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
cancelBtn.TextScaled = true
cancelBtn.Font = Enum.Font.Gotham
cancelBtn.Text = "Cancel"
cancelBtn.ZIndex = 10
cancelBtn.Parent = popup

local confirmBtn = Instance.new("TextButton")
confirmBtn.Name = "Confirm"
confirmBtn.Size = UDim2.new(0, 140, 0, 40)
confirmBtn.Position = UDim2.new(0.5, 80, 1, -15)
confirmBtn.AnchorPoint = Vector2.new(0.5, 1)
confirmBtn.BackgroundColor3 = Color3.fromRGB(60, 160, 60)
confirmBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
confirmBtn.TextScaled = true
confirmBtn.Font = Enum.Font.GothamBold
confirmBtn.Text = "Confirm"
confirmBtn.ZIndex = 10
confirmBtn.Parent = popup

local pendingGuess = nil

cancelBtn.MouseButton1Click:Connect(function()
	confirmGui.Enabled = false
	pendingGuess = nil
end)

confirmBtn.MouseButton1Click:Connect(function()
	if pendingGuess then
		hasGuessed = true
		currentGuess = pendingGuess
		guessLabel.Text = "Your Guess: " .. currentGuess
		Remotes.LogGuess:FireServer(pendingGuess)
		confirmGui.Enabled = false
		pendingGuess = nil
		clearHighlight()
		clickSound:Play()
	end
end)

-- Anomaly Tool
local scanner = Instance.new("Tool")
scanner.Name = "Anomaly Tool"
scanner.RequiresHandle = false
scanner.ToolTip = "Investigate objects for anomalies"
scanner.Parent = backpack

scanner.Equipped:Connect(function()
	toolEquipped = true
end)

scanner.Unequipped:Connect(function()
	toolEquipped = false
	clearHighlight()
end)

scanner.Activated:Connect(function()
	if currentPhase ~= "search" then return end
	if hasGuessed then return end
	if pendingGuess then return end
	if confirmGui.Enabled then return end

	local mouse = player:GetMouse()
	if not mouse or not mouse.Target then return end

	local floorObject = getFloorObject(mouse.Target)
	if not floorObject then return end

	clearHighlight()
	confirmGui.Enabled = true
	pendingGuess = floorObject:GetAttribute("Replaces") or floorObject.Name
	popupTitle.Text = "Confirm your guess"
	popupBody.Text = '"' .. pendingGuess .. '"'
end)

-- No Anomaly tool
local noAnomaly = Instance.new("Tool")
noAnomaly.Name = "No Anomaly"
noAnomaly.RequiresHandle = false
noAnomaly.ToolTip = "Nothing seems wrong"
noAnomaly.Parent = backpack

noAnomaly.Activated:Connect(function()
	if currentPhase ~= "search" then return end
	if hasGuessed then return end
	if confirmGui.Enabled then return end

	confirmGui.Enabled = true
	pendingGuess = "NoAnomaly"
	popupTitle.Text = "Are you sure?"
	popupBody.Text = "Do you want to claim there is no anomaly?"
end)

-- Hover highlight: mouse-based on desktop, camera-center raycast on mobile
RunService.RenderStepped:Connect(function()
	if not toolEquipped or hasGuessed or confirmGui.Enabled then
		clearHighlight()
		return
	end

	if isMobile then
		local camera = workspace.CurrentCamera
		if not camera then return end

		local params = RaycastParams.new()
		params.FilterType = Enum.RaycastFilterType.Blacklist
		params.FilterDescendantsInstances = {player.Character}

		local result = workspace:Raycast(
			camera.CFrame.Position,
			camera.CFrame.LookVector * 100,
			params
		)

		if result and result.Instance then
			local floorObject = getFloorObject(result.Instance)
			if floorObject and floorObject ~= hoveredObject then
				setHighlight(floorObject)
			elseif not floorObject then
				clearHighlight()
			end
		else
			clearHighlight()
		end
	else
		local mouse = player:GetMouse()
		if not mouse or not mouse.Target then return end

		local floorObject = getFloorObject(mouse.Target)
		if floorObject and floorObject ~= hoveredObject then
			setHighlight(floorObject)
		elseif not floorObject then
			clearHighlight()
		end
	end
end)

-- Reset on new round
Remotes.RoundStart.OnClientEvent:Connect(function()
	hasGuessed = false
	currentGuess = nil
	currentPhase = ""
	guessLabel.Text = "Your Guess: None"
	clearHighlight()
	confirmGui.Enabled = false
end)

Remotes.FloorReset.OnClientEvent:Connect(function()
	hasGuessed = false
	currentGuess = nil
	guessLabel.Text = "Your Guess: None"
	clearHighlight()
	confirmGui.Enabled = false
end)

-- Track phase and show guess display during search
Remotes.RoundTimerTick.OnClientEvent:Connect(function(seconds, phase)
	currentPhase = phase
	guessGui.Enabled = (phase == "search")
end)

-- Show results on reveal
Remotes.RevealResults.OnClientEvent:Connect(function()
	toolEquipped = false
	clearHighlight()
	guessGui.Enabled = false
end)
]]></string>
      </Properties>
    </Item>
  </Item>
</roblox>